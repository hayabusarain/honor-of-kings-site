    "skill3": {
      "name": "敬畏の盾",
      "tags": [
        "シールド",
        "スーパーアーマー",
        "ダメージ"
      ],
      "cooldown": "CD : 25秒",
      "description": "盾を構えて1200（1200+追加物理の16%）のシールド（発動中はCC無効）を獲得する。1.5秒後に聖盾で反撃し、範囲内の敵に450（450+追加物理の150%）の魔法ダメージを与える。盾を構えている間の敵ヒーローからのダメージ1回につき聖盾による反撃ダメージが10%増加し、発動時間が10%減少する（最大5スタック）。",
      "icon": "/images/skills/hero_069_skill3.png",
      "forms": [
        {
          "form_name": "通常",
          "description": "盾を構えて1200（1200+追加物理の16%）のシールド（発動中はCC無効）を獲得する。1.5秒後に聖盾で反撃し、範囲内の敵に450（450+追加物理の150%）の魔法ダメージを与える。盾を構えている間の敵ヒーローからのダメージ1回につき聖盾による反撃ダメージが10%増加し、発動時間が10%減少する（最大5スタック）。",
          "table": null
        },
        {
          "form_name": "勝利の叫び",
          "description": "最も近い味方タワーに移動する。飛び立つ際に範囲内の敵に600（600+物理攻撃の180%）の物理ダメージ（ヒーローレベルに応じて増加）を与えて0.75秒間ノックアップする。同時に周囲の味方を守護し、守護した味方を共にタワーまで移動させる。\n復活時間が10秒に満たない場合、アクティブスキルは使用できない。\n死亡中にスキル3を発動している場合、復活時に味方の守護及びその後の効果を付与できない。",
          "table": {
            "headers": [
              "Lv.1",
              "Lv.2",
              "Lv.3"
            ],
            "rows": [
              {
                "label": "クールダウン",
                "values": [
                  "45",
                  "40",
                  "35"
                ]
              }
            ]
          }
        }
      ]
    },
    "strategy": {
      "strengths": [
        "複数の移動スキルを持ち、逃げる敵を逃さず後衛に貼り付く極めて高い機動力",
        "死亡後も霊体となってマップを移動し、味方に視界やバフを提供しつつその場で復活できる独自のパッシブ"
      ],
      "weaknesses": [
        "行動阻害（CC）を受けるとコンボが途切れ、耐久力も高くないため簡単に倒されてしまう",
        "一度飛び込むと自力で離脱するのが難しく、エンゲージ後のリスクが高い"
      ],
      "playstyle": "序盤からアグレッシブにジャングルを回り、高い機動力を活かしてガンクやオブジェクトコントロールでスノーボールを狙うアサシン系ファイターです。集団戦では味方のタンクが敵のCCを吸い出した後、無防備になった敵のキャリーを狙って飛び込みます。死亡時も霊体として敵ジャングルなどの視界を確保し、チームに貢献し続けることが重要です。"
    },
