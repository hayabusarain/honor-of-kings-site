    "status_text": "見習いサポート 0/100\nサポート/メイジ\n攻撃系サポート\nCC/先手\n序盤\n難易度：ハード\n防御ステータス\n耐性 0%\n5秒ごとのHP回復 79\n5秒ごとのMP回復 15",
    "strategy": {
      "strengths": [
        "スキル2のフックによる強力な強制移動で、敵を味方陣地に引きずり込める",
        "序盤から敵ジャングルやレーンにプレッシャーを与え、アルティメットで強力な範囲CCを提供できる"
      ],
      "weaknesses": [
        "フックの命中精度に性能の大部分が依存しており、外した際の隙とプレッシャー低下が著しい",
        "機動力が低く、接近戦に持ち込まれると逃げる手段に乏しい"
      ],
      "playstyle": "主にローム（サポート）としてプレイし、序盤から積極的に敵の妨害や視界確保に動いてプレッシャーを与え続けます。集団戦の前後では、フックで敵の後衛キャリーを引っ張り出し、アルティメットのCCコンボで一瞬で倒し切る「ピックオフ」を狙うのが最大の役割です。誤って敵の強力なタンクやエンゲージャーを引き寄せてしまうと逆に味方を壊滅させる危険があるため、ターゲット選びは慎重に行う必要があります。"
    },
    "meta": {
      "summoner_spells": [
        "気絶",
        "閃現"
      ],
      "synergy": [
        {
          "hero_name": "黄忠",
          "reason": "鍾馗がフックで引き寄せた敵を、圧倒的な砲撃火力で瞬時に撃破できるため。",
          "hero_id": "hero_075"
        },
        {
          "hero_name": "孫尚香",
          "reason": "引き寄せた敵に対して高火力のバーストダメージを叩き込んで即座にキルに繋げやすいため。",
          "hero_id": "hero_014"
        }
      ],
      "counters": [
        {
          "hero_name": "曹操",
          "reason": "高いサステイン能力と妨害耐性で鍾馗のコントロールを抜けやすく、逆に反撃されてしまうため。",
          "hero_id": "hero_029"
        },
        {
          "hero_name": "カイザー",
          "reason": "ウルト発動中は非常に硬く、引き寄せてしまうと逆に味方が大ダメージを受ける危険があるため。",
