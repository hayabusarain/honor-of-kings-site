    },
    "status_text": "荘子 そうし 夢幻の賢者 見習いサポート 0/100 サポート/タンク 守護系サポート チームバフ 終盤 難易度：イージー",
    "strategy": {
      "strengths": [
        "味方全体をCC（行動不能）状態から解放できる、強力なアンチCC能力。",
        "高いダメージ軽減率と機動力による優れた生存能力と、持続的なダメージ出力。"
      ],
      "weaknesses": [
        "確定で敵を捕まえるハードCC（スタン等）を持たないため、自分から戦闘を仕掛けるのが苦手。",
        "敵チームにCC持ちが少ない場合や、割合ダメージ持ちが多い場合は腐りやすい。"
      ],
      "playstyle": "敵のCCスキルが強力な構成に対するカウンターピックとして非常に優秀です。集団戦では前線で敵の攻撃やヘイトを集めつつ、味方が致命的なCCを受けた瞬間にアルティメットを発動して救出します。自分からキルを取るのではなく、常に味方の位置を把握し、デバフ解除とダメージ軽減でチーム全体をサポートする立ち回りが求められます。"
    },
    "meta": {
      "summoner_spells": [
        "閃現",
        "処刑"
      ],
      "synergy": [
        {
          "hero_name": "Lady Sun",
          "reason": "CC解除によって彼女の機動力を活かし続け、安全に継続的な高火力を出させるため。",
