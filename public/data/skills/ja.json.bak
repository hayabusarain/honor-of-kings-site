      "synergy": [
        {
          "hero_name": "Zhuangzi",
          "reason": "ダメージ軽減やCC無効化を付与し、花木蘭が敵陣へ深く飛び込む際の安全性を高めてくれるため。",
          "hero_id": "hero_015"
        }
      ],
      "counters": [
        {
          "hero_name": "Liang",
          "reason": "対象指定の強力なハードCCで、重剣フォームによる高火力を出す前に完全に拘束されてしまうため。",
          "hero_id": "hero_049"
        },
        {
          "hero_name": "Mi Yue",
          "reason": "高い機動力とサステイン能力で花木蘭のコンボを回避・吸収され、逆に体力を削られてしまうため。",
          "hero_id": "hero_023"
        }
      ]
    },
    "strategy": {
      "strengths": [
        "双剣モード（機動力と沈黙）と重剣モード（ダメージ軽減と高火力）を切り替え、状況に合わせた柔軟な戦闘ができる。",
        "双剣モードのコンボで対象に沈黙を付与し、反撃を許さずに孤立したターゲットを仕留める能力が高い。",
        "重剣モード中はスーパーアーマーと最大50%の被ダメージ軽減を得るため、集団戦でも強引に火力を出せる。"
      ],
      "weaknesses": [
        "モード切り替えやコンボの操作が非常に複雑で、習熟するまでに多くの練習が必要な上級者向けヒーロー。",
        "接近前に強力なCCチェーンを受けると、重剣モードで耐える前に倒されてしまう。",
        "序盤のレーン戦が強いファイターやサステイン（回復力）の高いタンクを相手にすると、ファームで遅れを取りやすい。"
      ],
      "playstyle": "序盤は無理なトレードを避け、安全にファームしてコアアイテムとクールダウン短縮を揃えることに集中します。中盤以降は機動力を活かしてサイドレーンを押しつつ、敵のキャリーを狙って奇襲を仕掛けましょう。フラッシュとスキルを組み合わせたコンボで瞬時に距離を詰め、双剣で沈黙を与えた直後に重剣へ切り替えて一気にバーストダメージを叩き込むのが基本戦術です。"
    }
  },
