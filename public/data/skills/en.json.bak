    "status_text": "Max HP: 3369\nMax Mana: 560\nPhysical Attack: 180 (170+10)\nMagical Attack: 0\nPhysical Defense: 150|20%\nMagical Defense: 75|11.1%\nMovement Speed: 385\nPhysical Pierce: 0|0%\nMagical Pierce: 0|0%\nAttack Speed: 5%\nCrit Rate: 0%\nCrit Damage: 200%\nPhysical Lifesteal: 0%\nMagical Lifesteal: 0%\nCooldown Reduction: 0%\nAttack Range: Melee\nResistance: 0%\nHP Regen/5s: 51\nMana Regen/5s: 14",
    "strategy": {
      "strengths": [
        "Excellent pick-off potential by using his hook to catch and displace enemies, breaking their formation.",
        "Ranged basic attacks provide high sustained damage, and his passive makes him an unstoppable chaser after a kill."
      ],
      "weaknesses": [
        "Completely reliant on hitting his hook; missing it leaves him very vulnerable. Very high mechanical difficulty.",
        "Weak against crowd control and can severely punish his own team if he accidentally pulls in an enemy tank."
      ],
      "playstyle": "Clear the jungle quickly to reach level 4 and unlock your Ultimate before aggressively ganking. In teamfights, do not engage first; wait for major enemy skills to be blown, then play cleanup by hunting low-health targets. Maintain proper distance and consistently land your hook combo to isolate and eliminate squishy targets."
    },
    "meta": {
      "summoner_spells": [
        "Smite"
      ],
      "synergy": [
        {
          "hero_name": "Liang",
          "reason": "His guaranteed suppression locks targets down, making it extremely easy for Xuance to land his hook.",
          "hero_id": "hero_049"
        },
        {
          "hero_name": "Zhuangzi",
          "reason": "Provides CC cleanse and damage reduction, ensuring Xuance isn't chain-stunned when diving the enemy team.",
          "hero_id": "hero_015"
        }
      ],
      "counters": [
