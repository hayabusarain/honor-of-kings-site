    },
    "skill2": {
      "name": "Wind riding",
      "tags": [
        "move",
        "treatment",
        "damage"
      ],
      "cooldown": "CD: 0.2 seconds",
      "description": "Fly to the selected bush, obtain 1 stack of \"Firefly Power\", and summon 1 firefly every time you fly a certain distance. After 1 second, the fireflies fly towards the hero with the lowest HP, dealing 100 (100 + 20% of magic attack + 3% of additional maximum HP) magic damage to the enemy and inflicting stealth immunity for 3 seconds, or restoring 60 (60 + 10% of magic attack + 1.5% of additional maximum HP) HP of allied heroes.\nThis skill can be charged 3 times, and when tapped, it flies towards the selected bush.",
      "table": {
        "headers": [
          "Lv.1",
          "Lv.2",
          "Lv.3",
          "Lv.4",
