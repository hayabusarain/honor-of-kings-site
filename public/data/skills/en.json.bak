    "status_text": "",
    "strategy": {
      "strengths": [
        "Incredible mobility allows for fast jungle clears and potent ganks.",
        "Excellent at disrupting enemy formations using the forced displacement (push) of his ultimate."
      ],
      "weaknesses": [
        "Low durability makes him an easy target if caught by crowd control (CC).",
        "Requires precise skill chaining and combos, making his mechanical difficulty relatively high."
      ],
      "playstyle": "Roam the jungle and lanes rapidly from the early game, hunting isolated targets and squishy backliners to rack up kills. In team fights, don't initiate first; wait for the enemy to burn their primary CC skills before diving their backline. Mastering the flexibility of his ultimate—whether to push enemies toward your team or to escape dangerous situations—is key to his success."
    },
    "meta": {
      "summoner_spells": [
        "Smite"
      ],
      "synergy": [
        {
          "hero_name": "Liang",
          "reason": "His powerful CC pins down enemies, creating the perfect window for Lam to land his high-burst combos.",
          "hero_id": "hero_049"
        },
        {
          "hero_name": "Liu Shan",
          "reason": "Disrupts the enemy formation and draws attention at the frontline, creating safe opportunities for Lam to dive the backline.",
          "hero_id": "hero_016"
        }
      ],
      "counters": [
        {
          "hero_name": "Arthur",
          "reason": "His silence prevents Lam from chaining the skills he relies on for mobility, leaving him stranded.",
          "hero_id": "hero_054"
        },
        {
          "hero_name": "Mozi",
          "reason": "Frequent long-range stuns hinder Lam's approach, making it hard to utilize his high mobility.",
          "hero_id": "hero_013"
        }
      ]
    }
  },
