{
  "hero_538": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "共鳴・掠火",
        "tags": [],
        "cooldown_text": "",
        "description": "神槍「掠火」と心を通わせ、スキル発動時に共鳴を1スタック獲得する。通常攻撃時にスタックを全て消費し、スタック数に応じて共鳴スキル「堅意・戦止」、「鋭意・破城」、「真意・燎原」を発動し、「断月」と「追雲」のCDを1.5秒短縮する。\n共鳴スキルはクリティカルヒット可能。発動速度は自身の攻撃速度に応じて増加する（反映率50%）。",
        "table": null
      },
      {
        "id": "skill1",
        "name": "断月",
        "tags": [
          "CC",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "槍を前方へ突き上げ、その後に振り下ろす。180（180+追加物理攻撃の60%）の物理ダメージ（合計2回）を与え、突き上げ時に0.5秒間ノックアップする。",
        "table": null
      },
      {
        "id": "skill2",
        "name": "追雲",
        "tags": [
          "移動",
          "移動速度増加",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "槍を掲げ、チャージして突進する（最大で移動速度が25%増加）。チャージ終了後に前方に突進して薙ぎ払い、敵に180（180+追加物理攻撃の60%）～360（360+追加物理攻撃の120%）の物理ダメージを与え、移動速度を1秒間15%減少させる。",
        "table": null
      },
      {
        "id": "skill3",
        "name": "追星",
        "tags": [
          "突進",
          "CC",
          "スーパーアーマー"
        ],
        "cooldown_text": "",
        "description": "槍先に炎を宿らせ前方の範囲に向かって往復し、1回ごとに180（180+追加物理攻撃の60%）の物理ダメージを与えてノックアップする。\n最長距離に達すると連続で突き刺し、1回ごとに90（90+追加物理攻撃の30%）の物理ダメージを与える（合計4回）。\nスキル発動中はスーパーアーマー状態となり、被ダメージを30%軽減し、前方を薙ぎ払って燃焼させる2段階目のスキル「槍の咆哮」が発動可能になる。\n薙ぎ払いは180（180+追加物理攻撃の60%）の物理ダメージを与え、燃焼エリアは3秒間、0.2秒ごとに1回50（50+追加物理攻撃の16%）の魔法ダメージを与える。\n「追星」発動中に2段階目を発動できる。周囲を薙ぎ払い、その後の突進をキャンセルして120（120+追加物理攻撃の40%）の物理ダメージを与え、3秒間円形の範囲を燃焼させる。",
        "table": null
      }
    ]
  },
  "hero_169": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "裁きの矢",
        "tags": [],
        "cooldown_text": "",
        "description": "通常攻撃が敵に命中するたびに「裁きの矢」を1スタック獲得し（最大3スタックまで）、1スタックごとに3秒間攻撃速度が2%~4%増加する。\n最大までスタックすると、3秒間強化状態になる。強化状態中は、通常攻撃のたびに3本の矢を放ち（通常攻撃1回とみなす）、元の通常攻撃の120%の物理ダメージを与える。",
        "table": null
      },
      {
        "id": "skill1",
        "name": "乱れ矢雨",
        "tags": [
          "強化"
        ],
        "cooldown_text": "",
        "description": "5秒間自身を強化し、通常攻撃のたびに214（90+物理攻撃の75%）の物理ダメージを与える。パッシブスキルによる強化状態である場合、スキル1発動時に3本の矢を放ち、元の通常攻撃の120%の物理ダメージを与える。さらに、正面射程範囲内の敵2体またはタワー/クリスタルに50%のダメージ（通常攻撃特殊効果なし）を与える。",
        "table": null
      },
      {
        "id": "skill2",
        "name": "日没の残光",
        "tags": [
          "ダメージ",
          "移動速度減少",
          "視界"
        ],
        "cooldown_text": "",
        "description": "日の塔に指定位置を攻撃するよう命令し、そのエリアの視界を獲得する。\n一定時間経過後、範囲内の敵に480（480+魔法攻撃の110%）の魔法ダメージを与え、2秒間敵の移動速度を25~50%減少させる（端にいるターゲットに対しては移動速度減少効果とダメージが半減）。",
        "table": null
      },
      {
        "id": "skill3",
        "name": "灼熱の矢",
        "tags": [
          "CC",
          "移動速度減少",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "指定方向にフレイムアローを放つ。フレイムアローは敵ヒーローに命中すると爆発し、爆破範囲内の敵に800（800+物理攻撃の120%）の物理ダメージを与える。\nフレイムアローは最初に命中した敵ヒーローを0.75~3.5秒間（フレイムアローの飛行距離に応じて変化）スタンさせ、爆発範囲内にいる敵の移動速度を1秒間30%減少させる。",
        "table": null
      }
    ]
  },
  "hero_105": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "Courageous Resolve",
        "tags": [],
        "cooldown_text": "",
        "description": "Becomes super armored while skill is active.\nFighting spirit continues to increase while in combat, and increases further when a normal attack or skill hits an enemy. Acquires a damage reduction effect of 0-20% depending on the amount of fighting spirit. At maximum fighting spirit, attack speed increases by 30%.\nWhen you leave the combat state, fighting spirit is gradually converted to HP, recovering 70 (70 + 1.5% of additional HP) each time (up to 10 times).",
        "table": null
      },
      {
        "id": "skill1",
        "name": "Burst Charge",
        "tags": [
          "CC",
          "move",
          "damage"
        ],
        "cooldown_text": "",
        "description": "Charges in the specified direction for 0.5 seconds, dealing 150 (150 + 3% of additional HP) physical damage to enemies along the route and knocking them up.\nPassive effect: The third normal attack becomes a heavy attack, dealing an additional 250 (250 + 100% of additional physical attack) physical damage.",
        "table": null
      },
      {
        "id": "skill2",
        "name": "Magma Smash",
        "tags": [
          "damage",
          "shield",
          "Movement speed decreased"
        ],
        "cooldown_text": "",
        "description": "After charging on the spot, inject energy into the ground with your shield and gain a 400 (400 + 10% of additional HP) shield for 5 seconds. While charging, reduces the movement speed of enemies within range by 15% and draws non-hero enemy units towards the center.\nAfter 1 second, the ground explodes, dealing 330 (330 + 110% of additional physical attack) physical damage to enemies within the area. The closer you are to the center, the more damage the enemy takes, up to a maximum of 100% additional damage.\nIf there are enemies within the skill range while charging, reset the cooldown of skill 1.\nOther skills can be activated while skill 2 is activated.",
        "table": null
      },
      {
        "id": "skill3",
        "name": "Trembling Earth",
        "tags": [
          "CC",
          "move",
          "damage"
        ],
        "cooldown_text": "",
        "description": "Jumps to the specified position and fires three blows towards the ground. The position of each hit can be adjusted using the direction keys.\n1st time: Deals 200 (200 + 5% of additional HP) physical damage to enemies within range and reduces enemy movement speed by 15% for 1 second. Deals additional physical damage (60% of additional physical attack) to enemies in the center of the range.\n2nd time: Deals 300 (300 + 10% of additional HP) physical damage to enemies within range and reduces enemy movement speed by 30% for 1 second. Deals additional physical damage (90% of additional physical attack) to enemies in the center of the range.\n3rd time: Deals 500 (500 + 15% of additional HP) physical damage to enemies within range and knocks them up for 1 second. Deals additional physical damage (150% of additional physical attack) to enemies in the center of the area.\nSkill 1 can be activated while Skill 3 is activated.",
        "table": null
      }
    ],
    "hero_id": "105",
