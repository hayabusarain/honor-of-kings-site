    "status_text": "apprentice marksman 0/100\nMarksman\nRapid-fire Marksman\nCharge/Long Range Poke\nbalance\nDifficulty: Hard\ndefense status\nresistance 0%\nHP recovery every 5 seconds 36\nMP recovery every 5 seconds 15",
    "strategy": {
      "strengths": [
        "Skill 2 nullifies physical damage, making it extremely strong in 1v1 against physical assassins and marksmen.",
        "Skill 1's powerful long-range poke ability and ultimate's single burst/self-defense ability"
      ],
      "weaknesses": [
        "Since it only has physical immunity, it is extremely vulnerable to heroes that mainly deal magic damage (mages, etc.)",
        "Does not have pure movement skills such as dash, and has low mobility while skill 2 is on cooldown."
      ],
      "playstyle": "In the early stages, use Skill 1's long-range range to farm and harass from a safe position. In group battles, never move too far forward, and when a physical enemy approaches, use Skill 2 to nullify the damage and counter attack, which is a powerful counter strategy. If the enemy is in a configuration that deals a lot of magic damage, avoid picking, or always take a position behind your allies, paying close attention to where you stand."
    },
    "meta": {
      "summoner_spells": [
        "epiphany"
      ],
      "synergy": [
        {
          "hero_name": "Gyuma",
          "reason": "This is because it can stop the enemy with a powerful movement blocker and create an opening for Gubijin's long-range pokes and ults to reliably hit.",
          "hero_id": "hero_056"
        },
        {
          "hero_name": "East Emperor Taichi",
          "reason": "This allows you to securely protect yourself from enemy assassin dives and buy time to safely output damage.",
          "hero_id": "hero_071"
        }
      ],
      "counters": [
        {
          "hero_name": "Erin",
          "reason": "She is a marksman whose normal attacks deal magic damage, and Yuubito's physical attack nullification skills have no meaning at all.",
          "hero_id": "hero_048"
        },
        {
          "hero_name": "Diao cicada",
          "reason": "With high mobility and continuous attacks that deal guaranteed/magic damage, you can ignore physical immunity and defeat them unilaterally.",
          "hero_id": "hero_040"
        }
      ]
    }
  },
