    "strategy": {
      "strengths": [
        "Due to the high damage reduction by passive, it is very strong in 1v1 and fistfights between Fighters.",
        "By applying skills continuously, you can easily stick to the enemy and relentlessly pursue the fleeing opponent."
      ],
      "weaknesses": [
        "If the activation of a skill is interrupted by CC, the passive will not activate and it will become vulnerable all at once.",
        "You need to prepare to accumulate stacks with pokes, and it is dangerous to jump in without an ally's initiation."
      ],
      "playstyle": "In the early stages, you can safely accumulate stacks with skill 1's long-range poke, and show your true value from the middle stages onwards when the skill turnover rate increases. Hit your skills repeatedly to get additional damage and damage reduction buffs, and stick to your enemies to deal continuous damage. In group battles, instead of rushing in headfirst, it's ideal to match your allies' CC, or take advantage of the timing when the enemy's CC is depleted and finish off the enemy's carry with a duel."
    },
    "meta": {
      "summoner_spells": [
        "Flash"
      ],
      "synergy": [
        {
          "hero_name": "Mai Shiranui",
          "reason": "強力なCCで敵を拘束してくれるため、パッシブをスタックしやすくコンボを繋げやすい。",
          "hero_id": "hero_050"
        },
        {
          "hero_name": "Guiguzi",
          "reason": "By gathering multiple enemies in one place, you can maximize area damage and recovery effects.",
          "hero_id": "hero_072"
        }
      ],
      "counters": [
        {
          "hero_name": "Arthur",
          "reason": "Silence forces skill combos to be interrupted and prevents stacking of passives.",
          "hero_id": "hero_054"
        },
        {
          "hero_name": "Arli",
          "reason": "Due to its high mobility and kite ability, it does not allow you to get close, and you can only deal damage from a distance.",
          "hero_id": "hero_081"
        }
      ]
    }
  },
  "hero_103": {
    "hero_id": "103",
    "hero_name": "Yun-ei",
