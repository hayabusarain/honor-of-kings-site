    "strategy": {
      "strengths": [
        "Excellent versatility in offense and defense, allowing you to switch between two stances: damage and recovery.",
        "High survivability and continuous combat ability that takes advantage of the untargetable state due to ultimate"
      ],
      "weaknesses": [
        "The base has low durability and is vulnerable if caught by CC and receives burst damage.",
        "The sense of distance to apply stun (skill 2) is severe, and the instantaneous burst firepower is modest."
      ],
      "playstyle": "Operates in the mid lane and fights while switching between blue (damage) and green (recovery) stances depending on the battle situation. When aiming for a stun with skill 2, there is a risk of getting close to the enemy, so it is necessary to move around from a safe distance in time for the engagement of allies. Save your ultimate not just as a recovery skill, but as a powerful self-defense tool to avoid enemy fatal attacks and CC, and prioritize surviving team fights for a long time."
    },
    "meta": {
      "summoner_spells": [
        "epiphany"
      ],
      "synergy": [
        {
          "hero_name": "Hakuki",
          "reason": "This is because it is a tank that can endure for a long time on the front lines, and can take full advantage of Yang Yuhuan's continuous recovery and damage support.",
          "hero_id": "hero_022"
        },
        {
          "hero_name": "Sun Yin",
          "reason": "They are strong in long-term battles where they buff each other's recovery and movement speed, raising the durability and mobility of the entire team.",
          "hero_id": "hero_020"
        }
      ],
      "counters": [
        {
          "hero_name": "Hanshin",
          "reason": "Due to their overwhelming mobility, they were able to quickly close the distance, and Yang Yuhuan was defeated before she could recover her allies.",
          "hero_id": "hero_044"
        },
        {
          "hero_name": "100 miles of promise",
          "reason": "This is because he can safely inflict fatal injuries with ultra-long range sniping from outside of Yang Yuhuan's attack/recovery range.",
          "hero_id": "hero_078"
        }
      ]
    }
  },
  "hero_064": {
    "hero_id": "064",
    "hero_name": "Cang",
    "hero_title": "Descendant of the Blue Wolf",
    "role": "Marksman",
