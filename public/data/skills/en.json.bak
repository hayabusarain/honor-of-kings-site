      "icon": "/images/skills/hero_085_skill3.png"
    },
    "status_text": "Basic status\nMax HP 2913 (2793+120)\nMax MP 620\nPhysical attack 165\nMagic attack 0\nPhysical defense 150|20%\nMagic defense 75|11.1%\nattack status\nMovement speed 365\nPhysical defense penetration 0|0%\nMagic defense penetration 0|0%\nAttack speed bonus 5%\nCritical rate 0%\nCritical effect 200%\nPhysical life steal 0%\nMagic life steal 0%\nCooldown reduction 0%\nAttack range long distance\ndefense status\nResistance 0%\nHP recovery every 5 seconds 36\nMP recovery every 5 seconds 15",
    "strategy": {
      "strengths": [
        "Possess allies (especially Assassins and Marksmen) to provide powerful shields and buffs to maximize their survivability.",
        "Has mini-stun and knockback from targeted tracking bullets, and has excellent peel ability to protect allies.",
        "His survivability is extremely high due to his passive ability to turn into a deer that cannot be targeted when receiving Hard CC."
      ],
      "weaknesses": [
        "It is very weak in the early stages until you reach level 4 and learn the ultimate, and its influence in lane battles is low.",
        "It is a passive support that is completely dependent on allies, and cannot demonstrate its true value in a configuration without a strong carry or vanguard tank.",
        "Since it cannot set up a front line by itself, it is vulnerable to high firepower and high durability configurations that quickly destroy shields."
      ],
      "playstyle": "Collect experience points safely until you reach level 4, and aim to learn the ultimate as soon as possible. After acquiring the ultimate, possess the most developed carry in your team and create an environment where they can easily move by securing visibility and CC using skills. It is also effective to take advantage of the advanced tactics of taking advantage of an enemy's important CC skills and automatically turning into a deer (invincible state) to waste the skills."
    },
    "meta": {
      "summoner_spells": [
        "obstruction",
        "treatment"
      ],
      "synergy": [
        {
          "hero_name": "Marco Polo",
          "reason": "She has high mobility, and Yaria's shield and CC perfectly support her ult dive.",
          "hero_id": "hero_033"
        },
        {
          "hero_name": "Yunzhongjun",
          "reason": "He is a highly mobile Assassin, and when possessed by Yaria, he is able to perform powerful ganks that ignore terrain.",
          "hero_id": "hero_086"
        }
      ],
      "counters": [
        {
          "hero_name": "Garo",
          "reason": "Due to the shield-effective passive and long range, Yaria's strong point, the shield, can be easily stripped away.",
          "hero_id": "hero_088"
        },
        {
          "hero_name": "Kansho Moja",
          "reason": "Due to the overwhelming burst damage, the possessed ally will be blown away along with the shield.",
          "hero_id": "hero_068"
        }
      ]
    }
  },
