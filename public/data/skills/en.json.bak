      "weaknesses": [
        "Easily neutralized by long-range poke and kiting comps with heavy slows, making it very difficult for him to close the gap.",
        "Extremely reliant on his Ultimate; if it misses or is wasted, his damage output plummets."
      ],
      "playstyle": "A late-game jungle fighter who uses CC cleanses and true damage to aggressively chop down any enemy in his path. In team fights, avoid being the first to dive; wait until the enemy burns their main skills, then leap in with your Ultimate and pop your Skill 2 buff to sweep the floor. Focus heavily on farming in the early game to get your core items as fast as possible."
    },
    "meta": {
      "summoner_spells": [
        "Smite"
      ],
      "synergy": [
        {
          "hero_name": "Sun Bin",
          "reason": "His acceleration and healing support help Dian Wei close the gap and force his massive damage onto the enemy.",
          "hero_id": "hero_020"
        },
        {
          "hero_name": "Zhuangzi",
          "reason": "His team-wide CC cleanse gives Dian Wei the perfect environment to rampage continuously without worrying about being stopped.",
          "hero_id": "hero_015"
        }
      ],
      "counters": [
        {
          "hero_name": "Mi Yue",
          "reason": "Her high mobility and stat-draining tether completely deny Dian Wei's approach, allowing her to easily kite and whittle him down.",
          "hero_id": "hero_023"
        },
        {
          "hero_name": "Zhang Liang",
          "reason": "His Ultimate is a powerful suppression that cannot be cleansed by Dian Wei's passive, instantly shutting down his charge.",
          "hero_id": "hero_049"
        }
      ]
    }
  },
