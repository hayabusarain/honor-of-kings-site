    "status_text": "status\nBasic status\nMax HP 3257\nMax MP 600\nphysical attack 175(165+10)\nmagic attack 0\nphysical defense 150|20%\nmagic defense 75|11.1%\nattack status\nmovement speed 360\nPhysical defense penetration 0|0%\nMagic defense penetration 0|0%\nattack speed bonus 10%\nCritical rate 0%\ncritical effect 200%\nphysical life steal 0%\nmagic life steal 0%\nCooldown reduction 0%\nAttack range long distance\ndefense status\nresistance 0%\nHP recovery every 5 seconds 37\nMP recovery every 5 seconds 15",
    "strategy": {
      "strengths": [
        "Very high damage output in the early stages, making it easy to take control of the match",
        "Passive visibility and ability to quickly process objects such as towers and epic monsters."
      ],
      "weaknesses": [
        "If the match is long and becomes a late game, it will lack firepower compared to traditional hyper carry.",
        "Most of the damage is skill dependent, and if you get caught by CC you will be defeated without being able to do anything."
      ],
      "playstyle": "Take advantage of your overwhelming firepower in the early stages to actively create an advantage in lanes and jungles, quickly secure important objects such as dragons, and aim for snowballs. In group battles, do not use your movement skill (skill 2) for easy attacks, but instead use it as a means of self-defense to distance yourself from enemy assassins. The basic idea is to mark the enemy with skill 1 from a safe position and detonate it with a normal attack to steadily reduce the enemy's health."
    },
    "meta": {
      "summoner_spells": [
        "punishment",
        "epiphany"
      ],
      "synergy": [
        {
          "hero_name": "Liu Shan",
          "reason": "This is because you can restrain the enemy with a wealth of movement obstructions and ensure that Fang's skill damage hits in full.",
          "hero_id": "hero_016"
        },
        {
          "hero_name": "Zhang Fei",
          "reason": "It protects you while controlling your enemies, giving you a safe amount of time to build up your bomb stacks.",
          "hero_id": "hero_058"
        }
      ],
      "counters": [
        {
          "hero_name": "Xiahou Dun",
          "reason": "This is because he can block Fang's mobility with powerful continuous CC and stop him from moving before he can do all the damage.",
          "hero_id": "hero_027"
        },
        {
          "hero_name": "arrogance",
          "reason": "Skill 2 can remove Fang's bomb mark, which negates the deadly burst damage.",
          "hero_id": "hero_034"
        }
      ]
    }
  },
