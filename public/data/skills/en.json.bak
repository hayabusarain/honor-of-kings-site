    "strategy": {
      "strengths": [
        "Possesses multiple movement skills and extremely high mobility to stick to the rear without missing the fleeing enemy.",
        "A unique passive that allows you to move around the map as a spirit even after death, providing vision and buffs to your allies while reviving on the spot."
      ],
      "weaknesses": [
        "If you receive CC, your combo will be interrupted, and your durability will not be high, so you will be defeated easily.",
        "Once you jump in, it is difficult to escape on your own, and the risk is high after engagement."
      ],
      "playstyle": "He is an assassin-type fighter who aggressively moves around the jungle from the beginning and uses his high mobility to aim for snowballs with ganks and object control. In group battles, friendly tanks will drain the enemy's CC and then dive in to attack the defenseless enemy carry. Even when you die, it is important to maintain your vision of the enemy jungle and continue to contribute to the team as a spirit."
    },
    "meta": {
      "summoner_spells": [
        "punishment"
      ],
      "synergy": [
        {
          "hero_name": "Zhang Fei",
          "reason": "Create a kill chance with CC and peel that match the engagement.",
          "hero_id": "hero_058"
        },
        {
          "hero_name": "Daruma",
          "reason": "Taking advantage of the opening Athena has opened, she can deal powerful follow-up damage.",
          "hero_id": "hero_035"
