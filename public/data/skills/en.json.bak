          "hero_id": "hero_013"
        },
        {
          "hero_name": "Donghuang Taiyi",
          "reason": "His suppression ultimate can instantly lock Li Bai down the moment he dashes in, ignoring his untargetability frames and guaranteeing his death.",
          "hero_id": "hero_071"
        }
      ]
    }
