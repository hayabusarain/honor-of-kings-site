    "status_text": "Apprentice Mage 0/100\nMage\nCC Mage\nCC/Freeze\nBalanced\nDifficulty: Hard",
    "strategy": {
      "strengths": [
        "A CC Mage who can freeze enemies with her passive, boasting an overwhelming impact in team fights.",
        "Her skills bounce and chain between multiple enemies, dealing more damage and CC the more grouped up they are.",
        "Relatively low item dependency and simple mechanics make her easy for beginners to contribute to the team."
      ],
      "weaknesses": [
        "Lacks mobility skills, making her very slow and extremely vulnerable to assassin ambushes or positioning mistakes.",
        "Low early game damage, making it hard to dictate the pace of the match until she gets her core items in the mid-game."
      ],
      "playstyle": "A CC-focused mage who supports allies and deals damage by constantly freezing and slowing the entire enemy team from the backline. In team fights, use her ultimate to create a large water zone and bounce her Skill 2 to collapse the enemy formation. Always position yourself safely behind allied tanks, keeping an eye on the map to avoid being targeted by assassins."
    },
    "meta": {
      "summoner_spells": [
        "Flash"
      ],
      "synergy": [
        {
          "hero_name": "Zhang Fei",
          "reason": "His knockbacks and stuns hold enemies together, making it much easier for Lady Zhen to hit multiple targets with her skills and ultimate.",
          "hero_id": "hero_058"
        },
        {
          "hero_name": "Sun Bin",
          "reason": "His acceleration covers Lady Zhen's lack of mobility, and his lockdown helps her trigger her passive freeze more consistently.",
          "hero_id": "hero_020"
        }
      ],
      "counters": [
        {
          "hero_name": "Li Bai",
