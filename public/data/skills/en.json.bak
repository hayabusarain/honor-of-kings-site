    "status_text": "",
    "passive": {
      "name": "Resonance/Burning",
      "description": "Communicate with the divine spear \"Kasuka\" and gain 1 stack of resonance when the skill is activated. Consumes all stacks during a normal attack, activates the resonance skills ``Firmness - Battle Stop'', ``Eagerness - Breaking Castle'', and ``True Intention - Ryohara'' according to the number of stacks, and shortens the CD of ``Dangetsu'' and ``Oigumo'' by 1.5 seconds.\nResonance skills can be critical hits. Activation speed increases according to own attack speed (reflection rate 50%).",
      "icon": "/images/skills/hero_103_passive.png"
    },
    "skill1": {
      "name": "Dangetsu",
      "tags": [
        "CC",
        "damage"
      ],
      "cooldown": "CD: 10 seconds",
      "description": "Raise the spear forward and then swing it down. Deals 180 (180 + 60% of additional physical attack) physical damage (2 times in total) and knocks up for 0.5 seconds when thrusting up.",
      "icon": "/images/skills/hero_103_skill1.png",
