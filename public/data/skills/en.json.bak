    "skill1": {
      "name": "Skill 1: Thunderblaze",
      "description": "Transforms into a torrent of lightning and charges forward, dealing 200 (200 + 45% of physical attack) magic damage to enemies along the route and gaining 340 (340 + 5% of additional HP) shield for 2.5 seconds.",
