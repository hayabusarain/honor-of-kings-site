    },
    "skill3": {
      "name": "Missile Mayhem",
      "tags": [
        "Damage"
      ],
      "cooldown": "CD: 60s",
      "description": "Meng Ya scans the surrounding area. If allied heroes attack enemies within range, a mark is applied to the target's location (up to 5). After scanning, he fires missiles that deal 450 (+120% extra Physical Attack) physical damage to enemies hit. Hits on the same target deal 75% reduced damage, and grant him 10 Anger. After scanning, he fires up to 1 missile per second for 8s (if canceled or interrupted, cooldown is reduced by 50%).\nExcited State: The minimum firing interval for subsequent missiles is reduced from 1s to 0.5s.\nHolding the skill expands the search range for up to 3s. While scanning, Meng Ya's movement speed increases by 50%.",
      "table": {
        "headers": [
          "Lv.1",
          "Lv.2",
          "Lv.3"
        ],
        "rows": [
          {
            "label": "Cooldown",
            "values": [
              "60",
              "55",
              "50"
            ]
          },
          {
            "label": "Base Damage",
            "values": [
              "450",
              "675",
              "900"
            ]
          }
        ]
      },
      "icon": "/images/skills/hero_097_skill3.png"
    },
    "status_text": "",
    "strategy": {
      "strengths": [
        "Exceptional at sustained Area of Effect (AoE) damage and long-range poke.",
        "Self-sustain in the \"Excited\" state allows him to survive longer and maintain high DPS in team fights."
      ],
      "weaknesses": [
        "Lacks mobility (dash) skills, making him highly vulnerable to assassin dives.",
        "Heavily reliant on his Anger gauge and items; struggles to make an impact if he falls behind early."
      ],
      "playstyle": "Always manage your Anger gauge and aim to enter team fights when it's near maximum. Due to low mobility, strictly position yourself safely behind allied tanks. Rely on the continuous damage from Skill 1 and the poke from Skill 2 to whittle down enemies. Prioritize Attack Speed and Cooldown Reduction items to maintain the \"Excited\" state and maximize your damage output."
    },
    "meta": {
      "summoner_spells": [
        "Flash",
        "Purify"
      ],
      "synergy": [
        {
          "hero_name": "Menki",
          "reason": "Acts as a frontline shield, creating a safe environment for Meng Ya to dish out sustained long-range damage.",
          "hero_id": "hero_080"
        },
        {
          "hero_name": "Agudo",
          "reason": "Provides excellent support and healing, perfectly setting up the conditions Meng Ya needs to maintain his DPS in team fights.",
          "hero_id": "hero_100"
        }
      ],
      "counters": [
        {
          "hero_name": "Mai Shiranui",
          "reason": "High mobility allows her to close the gap quickly and burst him down, exploiting his lack of escape tools.",
          "hero_id": "hero_050"
        },
        {
          "hero_name": "Pei",
          "reason": "Applies high pressure and mobility from the early game, easily getting close to deal lethal damage.",
          "hero_id": "hero_083"
        }
      ]
    }
  },
