    "strategy": {
      "strengths": [
        "With its passive stealth (invisibility) ability, it is possible to secure one-sided visibility and approach enemies without them noticing.",
        "Boasting high burst damage from the early stages, it is easy to instantly kill enemy mages and marksmen and snowball them.",
        "If you are in stealth mode, a warning mark will appear on the enemy just by being nearby, allowing you to apply psychological pressure and restrict their actions."
      ],
      "weaknesses": [
        "The influence decreases towards the end, and when enemies are loaded with armor or grouped together, it becomes difficult to kill them.",
        "There is a vulnerability unique to assassins, and if you miss a combo or receive CC, you will be easily defeated by a counterattack.",
        "Since he relies on his ultimate for much of his approach and damage output, his kill pressure is low during times when he doesn't have an ultimate."
      ],
      "playstyle": "From the beginning, quickly move around the jungle and use stealth to aggressively gank lanes to control the pace of the match. In group battles, don't rush in head-on, but wait until the enemy marksman or mage is isolated and use the Skill 2 → Ult → Skill 1 combo to take them down. If the match drags on, it is important to avoid unnecessary assassinations and use stealth to maintain visibility and keep the enemy in check."
    },
    "meta": {
      "summoner_spells": [
        "Smite"
      ],
      "synergy": [
        {
          "hero_name": "Guiguzi",
          "reason": "This is because it can support the enemy by lowering their defense power and taking their vision, and maximizes Lanlingou's burst damage.",
          "hero_id": "hero_072"
        },
        {
          "hero_name": "Zhang Fei",
          "reason": "This is because it attracts the enemy's attention in group battles, making it easier for the stealth Prince of Lanling to assassinate marksmen from behind.",
          "hero_id": "hero_058"
        }
      ],
      "counters": [
        {
          "hero_name": "Baili Shouyue",
          "reason": "Because they can secure their visibility with their skills, they can detect Prince of Lanling's stealth surprise attack in advance and take countermeasures.",
          "hero_id": "hero_078"
        },
        {
          "hero_name": "Ata",
          "reason": "He has extremely high durability and CC, and is able to withstand Lanlingo's burst damage and end up being restrained.",
          "hero_id": "hero_107"
        }
      ]
    }
  },
