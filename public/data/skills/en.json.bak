    "status_text": "",
    "strategy": {
      "strengths": [
        "Quick jungle laps and overwhelming object control using your pet's ball",
        "Has a high ability to support allies such as recovery and CC, and is strong in continuous battles in group battles."
      ],
      "weaknesses": [
        "The main body of the ball is extremely vulnerable to being hit and cannot withstand burst damage.",
        "It is necessary to maintain a distance from the enemy, and is not good at fighting in narrow jungles or strong dive configurations."
      ],
      "playstyle": "Taking advantage of the automatic absorption of camps by balls, you can control the tempo by quickly moving around the jungle and stealing monsters from the enemy's camp. The basic combo is to use skill 1 to heal your allies and increase attack speed, and use your ultimate to throw a ball to knock up the enemy. A suitable fighting style is to continuously deal damage while ensuring the safety of the main body, and quickly destroy objects such as towers and dragons with your allies."
    },
    "meta": {
      "summoner_spells": [
        "Smite"
      ],
      "synergy": [
        {
          "hero_name": "Dr. Bian",
          "reason": "Continuous recovery greatly increases the ability to continue fighting both when mounted and when not mounted.",
          "hero_id": "hero_021"
        },
        {
          "hero_name": "Zhang Fei",
          "reason": "It provides a solid front line and shield, allowing the main body to continue delivering firepower from a safe distance.",
          "hero_id": "hero_058"
        }
      ],
      "counters": [
        {
          "hero_name": "Han Xin",
          "reason": "Due to its extremely high mobility, it is easy for the jungle to be destroyed, and your farm in the early stages will be hindered.",
          "hero_id": "hero_044"
        },
        {
          "hero_name": "Lam",
          "reason": "This is because they are targeted when they are defenseless when they dismount, and it is difficult to escape due to their high pursuit ability.",
          "hero_id": "hero_098"
        }
      ]
    }
  },
  "hero_101": {
    "hero_id": "101",
    "hero_name": "Kei",
    "hero_title": "Firefly Traveler",
    "role": "Support/Mage",
    "sub_role": "Buff Support",
    "difficulty": "hard",
    "stats": {
      "survival": 7,
      "attack": 4,
      "skill": 9,
      "difficulty": 7
    },
    "passive": {
      "name": "Guardian of Fireflies",
      "description": "When you deal damage with a normal attack, a firefly will be summoned, dealing 100 (100 + 20% of magic attack + 3% of additional maximum HP) magic damage to the enemy and inflicting stealth immunity for 3 seconds. At regular intervals, recovers 60 HP (60 + 10% of magic attack + 1.5% of additional maximum HP) of the nearby ally hero with the lowest HP.\nIf there are no enemies nearby, charging a normal attack will restore 60 HP (60 + 10% of magic attack + 1.5% of additional maximum HP), but HP recovery of allies will be interrupted.",
      "icon": "/images/skills/hero_101_passive.png"
    },
    "skill1": {
      "name": "The power of kuwagi",
      "tags": [
        "CC",
        "treatment",
        "damage"
      ],
      "cooldown": "CD: 10 seconds",
      "description": "Channels the \"power of fireflies\" into the specified area, dealing 500 (500 + 10% of magic attack) magic damage to enemies within the area and knocking them up for 1 second. Hitting an enemy consumes Firefly's power and deals 100 (100 + 20% of magic attack + 3% of additional maximum HP) magic damage for each stack of Firefly's power.\nIf there are friendly heroes nearby, consume Firefly's Power and heal the lowest HP of the friendly hero by 60 (60 + 10% of magic attack + 1.5% of additional maximum HP) for each stack of Firefly's Power.\n\"Power of Firefly\": You can obtain 1 stack of Firefly's power every 1.5 seconds (up to 9 stacks). The skill range expands according to the number of stacks.",
      "table": {
        "headers": [
          "Lv.1",
          "Lv.2",
          "Lv.3",
          "Lv.4",
          "Lv.5",
          "Lv.6"
