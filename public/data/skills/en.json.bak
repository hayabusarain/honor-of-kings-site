        },
        {
          "hero_name": "Sumiko",
          "reason": "This is because it is easy to create a starting point for Hime Koman's combo with a long-distance stun.",
          "hero_id": "hero_013"
        }
      ],
      "counters": [
        {
          "hero_name": "arthur",
          "reason": "To completely block the movement of Hime Koman, who has reliable silence and relies on skill combos.",
          "hero_id": "hero_054"
        },
        {
          "hero_name": "Zhang Liang",
          "reason": "This is because she has an unavoidable suppression skill and can forcibly stop Hime Koman, who has high mobility.",
          "hero_id": "hero_049"
        }
      ]
    }
  },
  "hero_511": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "パイレーツマインド",
        "tags": [],
        "cooldown_text": "",
        "description": "失ったHPが低HPモードとして7秒間蓄積される。低HPモードのHPは敵ヒーロー/非ヒーローにダメージを与えるとそれぞれ40%/20%回復する（追加HP1000ごとにヒーロー1%、非ヒーロー0.5%回復割合が増加）。低HPモードのHPは7秒経過後1秒ごとに最大HPの3%ずつ減少していく。通常攻撃に70（70+追加物理攻撃の35%）の物理ダメージを付与する。",
        "table": null
      },
      {
        "id": "skill1",
        "name": "ウェーブ・ウォーク",
        "tags": [
          "CC",
          "スーパーアーマー",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "指定方向に跳び上がり、着地時に範囲内の敵に460（460+追加HPの13%）の物理ダメージを与える。その後再び飛び上がり、着地時に範囲内の敵に同量の物理ダメージを与え、0.5秒間ノックアップする。\nスキル1が複数の敵に命中した場合、敵1体ごとにダメージが20%減少し、最大で元のダメージの60%まで減少する。ミニオンには30%の追加ダメージを与える。\n2回目の着地時、指定方向に宙返りする。スキル1発動中はスーパーアーマー状態を獲得する。",
        "table": null
      },
      {
        "id": "skill2",
        "name": "シー・アンカー",
        "tags": [
          "CC",
          "移動",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "指定方向に錨を投げ、ルート上の敵に225（225+追加物理攻撃の70%）の物理ダメージを与え、1.5秒間敵の移動速度を30%減少させる。錨が壁などの地形に当たると突進してルート上の敵を壁にぶつけ、250（250+追加HPの10%）の物理ダメージを与え、0.5秒間スタンさせる。\nパッシブ効果：スキル2発動後に次回の通常攻撃を強化し、ターゲットを目の前に引き寄せる。",
        "table": null
      },
      {
        "id": "skill3",
        "name": "ゴーストシップ",
        "tags": [
          "地形",
          "ダメージ",
          "スーパーアーマー"
        ],
        "cooldown_text": "",
        "description": "扇形の範囲にヒーローユニットが通れない防壁を4秒間作り出す。防壁を作り出した瞬間、ホワイトアンカーは前方の敵に350（350+追加物理攻撃の120%）の物理ダメージを与える。\nスキル3発動中、ホワイトアンカーはスーパーアーマー状態になる。",
        "table": null
      }
    ]
  },
  "hero_558": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "マッドネスフェザー",
        "tags": [],
        "cooldown_text": "",
        "description": "ターゲットが遠い場合、通常攻撃で旋回する飛刃を投げる。飛刃が手元に戻るまで次の遠距離攻撃はできない。飛刃が戻る間際に通常攻撃をタップすると、素早く前方に移動し飛刃を跳ね返して再攻撃できる。攻撃速度1%ごとにダメージが1.5増加し、跳ね返すたびにダメージと飛刃の飛翔速度が5%増加する（最大3回まで）。\nターゲットが近い場合、近距離戦モードとなり、敵を素早く3回攻撃して合計物理攻撃の110%の物理ダメージを与える。\n通常攻撃のたびにターゲットに刻印をスタックし、「フェザーストーム」命中時にスタック数に応じて追加ダメージを与える。",
        "table": null
      },
      {
        "id": "skill1",
        "name": "インサニティステップ",
        "tags": [
          "強化",
          "ダメージ",
          "移動速度減少"
        ],
        "cooldown_text": "",
        "description": "周囲を薙ぎ払い、円形範囲の敵に250+追加物理攻撃の80%の物理ダメージを与えて移動速度を2秒間15%減少させる。\nその後、短い間移動速度が大幅に増加し、3秒間狂気状態となる。移動速度が25%増加（持続的に減少）し、攻撃速度が60%増加する。",
        "table": null
      },
      {
        "id": "skill2",
        "name": "フェザーストーム",
        "tags": [
          "ダメージ",
          "回復",
          "移動"
        ],
        "cooldown_text": "",
        "description": "前方に突進してルート上の敵をノックバック（CCなし）し、ルート上の敵に150+追加物理攻撃の50%の物理ダメージを与える。同時に、命中した敵全員の「斬羽の刻印」を発動し、刻印を付近の敵に拡散させる。\n前方の範囲内に敵がいた場合、華麗に舞いながら飛刃で8回連続攻撃する。1回につき110+追加物理攻撃の38%の物理ダメージを与え、自身のHPを45+追加HPの0.8%回復する（非ヒーローユニットに命中した場合の回復量は半減）。不屈状態の場合、最後の1回で100%の追加ダメージを与える。命中するたびにターゲットの刻印を1スタック消費し、追加で40+追加物理攻撃の15%の物理ダメージを与える。\n舞いながら移動可能で、このスキルを再発動するとキャンセルできる。舞いが発動しなかった場合、クールダウンが60%に短縮する。",
        "table": null
      },
      {
        "id": "skill3",
        "name": "ラストダンス",
        "tags": [
          "不屈",
          "強化",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "東君の栄光を再び取り戻し、付近の敵に400+追加物理攻撃の140%の物理ダメージを与え、一時的にHPが50%、移動速度が50%増加（持続的に減少）する。不屈状態は4秒間持続し、その間の回復効果は不屈状態終了時に反映される。\nスキル3がクールダウン中でない時に死亡した場合、一定時間経過後に復活し、付近の敵に400+追加物理攻撃の140%の物理ダメージを与えた後にクールダウンに入る。\nパッシブ：このスキルをレベルアップすると、「フェザーストーム」の攻撃回数が2回、近接通常攻撃の攻撃回数が1回増加し、増加分の通常攻撃は50の物理ダメージを与える。\nこの一時HPを全て失うと、不屈状態は即座に終了する。また、死亡からの復活時に獲得する一時HPは、通常発動時の50%となる。",
        "table": null
      }
    ]
  },
  "hero_563": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "運命の導き",
        "tags": [],
        "cooldown_text": "",
        "description": "運命を導く者は遠距離攻撃と近距離攻撃を切り替える。スキルと近距離通常攻撃が命中すると7秒間刻印を付与する。\n遠距離攻撃：凝縮した運命の力を遠くに放ち、命中した敵に165（物理攻撃の100%）の物理ダメージと（魔法攻撃の15%）の魔法ダメージを与える。\n近距離攻撃：神杖で周囲の全方向を攻撃し、165（物理攻撃の100%）の物理ダメージと（魔法攻撃の45%）の魔法ダメージを与える。",
        "table": null
      },
      {
        "id": "skill1",
        "name": "運命の神杖",
        "tags": [
