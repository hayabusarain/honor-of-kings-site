    "skill3": {
      "name": "Fate Retrospect",
      "tags": [
        "return",
        "damage",
        "recovery"
      ],
      "cooldown": "CD: 80 seconds",
      "description": "Record the location where you entered a long-range attack state due to Fateful Leap (only one location).\nExpands the area, reduces damage taken by 15% and recovers 400 (400 + 6% of additional HP) HP. While expanding the area, you will be in super armor state and will not be able to move. After 1.5 seconds, deals 400 (400 + 100% of magic attack) magic damage and returns to the recorded point. If there is a friendly tower within the area, return the tower to the state it was in 5 seconds ago.\nThe lower the HP, the higher the recovery effect (up to 2x).",
      "icon": "/images/skills/hero_109_skill3.png"
    },
    "status_text": "Basic status\nMax HP 3313\nMax MP 640\nPhysical attack 165\nMagic attack 10 (0+10)\nPhysical defense 150|20%\nMagic defense 75|11.1%\nattack status\nMovement speed 365\nPhysical defense penetration 0|0%\nMagic defense penetration 0|0%\nAttack speed bonus 5%\nCritical rate 0%\nCritical effect 200%\nPhysical life steal 0%\nMagic life steal 0%\nCooldown reduction 0%\nAttack range long distance\ndefense status\nResistance 0%\nHP recovery every 5 seconds 46\nMP recovery every 5 seconds 16",
    "strategy": {
      "strengths": [
        "Powerful poke and area control ability from a safe distance",
        "High survivability ability to survive in close combat even as a mage",
        "Overwhelming power in the late stages with equipment and cooldown reduction"
      ],
      "weaknesses": [
        "Low combat power in the early stages and weak against aggressive invaders",
        "Does not have a reliable hard CC that can spark a team fight",
        "If you get into the pocket with a strong hard engagement, you won't be able to use pokes and will be easily defeated."
      ],
      "playstyle": "In the early stages, avoid unnecessary battles and concentrate on growing safely by poking and farming from a distance. After the middle stage, when you have all the cooldown reduction items, you can constantly shoot skills from behind the vanguard and continue to whittle down the enemy's health. Ideally, you should maintain an appropriate sense of distance without overconfidence in your high self-survival ability, and continuously apply damage and pressure while dodging your opponent's dives."
    },
    "meta": {
      "summoner_spells": [
        "epiphany"
      ],
      "synergy": [
        {
          "hero_name": "doria",
          "reason": "Because you can reset the cooldown of skills and activate Heino's powerful ultimate continuously.",
          "hero_id": "hero_051"
        },
        {
          "hero_name": "Daqiao",
          "reason": "By combining teleport and Heino's ultimate that turns back time, it will be easier to return to the front and recover.",
          "hero_id": "hero_074"
        }
      ],
      "counters": [
        {
          "hero_name": "Butterfly",
          "reason": "This is because you can quickly close the distance and defeat Heino with high burst damage before he can recover.",
          "hero_id": "hero_112"
        },
        {
          "hero_name": "Zhang Fei",
          "reason": "Because it has strong CC and can create a starting point to restrain Heino and defeat him without using his ultimate.",
          "hero_id": "hero_058"
        }
      ]
    }
  },
