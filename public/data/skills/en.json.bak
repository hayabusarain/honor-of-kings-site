    "status_text": "Max HP: 3206\nMax MP: 640\nPhysical Attack: 166\nMagical Attack: 10 (0+10)\nPhysical Defense: 150 | 20%\nMagical Defense: 75 | 11.1%\nMovement Speed: 365\nPhysical Defense貫通: 0 | 0%\nMagical Defense貫通: 0 | 0%\nAttack Speed Bonus: 5%\nCritical Rate: 0%\nCritical Damage: 200%\nPhysical Lifesteal: 0%\nMagical Lifesteal: 0%\nCooldown Reduction: 0%\nAttack Range: Ranged\nResistance: 0%\nHP Regen/5s: 44\nMP Regen/5s: 16",
    "strategy": {
      "strengths": [
        "Excellent slow and freeze (stun) skills, highly capable of locking down enemies and creating kill opportunities.",
        "Ultimate deals massive AoE sustained damage and slow, excelling at team fight control and zone denial.",
        "Possesses relatively high self-peel among mages due to the passive shield gained out of combat."
      ],
      "weaknesses": [
        "Low base movement speed and lacks dash skills, making her vulnerable to highly mobile assassins.",
        "Skills have delayed casting times; landing her Ice Prison requires prediction and precise timing.",
        "Weak against enemies with CC immunity, cleanse, or high mobility to dodge her skills."
      ],
      "playstyle": "Farm safely to push waves early on, establishing mid-lane priority before roaming to support side lanes. In team fights, position behind your frontline. Do not blindly aim for a freeze; instead, apply slows with your Ultimate or Skill 1 first, making it much easier to land Skill 2. When defending towers or fighting in narrow jungle paths, use your Ultimate to completely block enemy entry."
    },
    "meta": {
      "summoner_spells": [
        "Flash",
        "Purify"
      ],
      "synergy": [
        {
          "hero_name": "Zhang Fei",
          "reason": "Draws aggro and locks down enemies at the front, making it easier for her to land Ice Prison.",
          "hero_id": "hero_058"
        },
        {
          "hero_name": "Zhou Yu",
          "reason": "Layering their massive AoE magic damage decimates enemies in team fights.",
          "hero_id": "hero_025"
        }
      ],
      "counters": [
        {
          "hero_name": "Mai Shiranui",
          "reason": "High mobility lets her easily dodge freezes and instantly burst Zhaojun down.",
          "hero_id": "hero_050"
        },
        {
          "hero_name": "Zhuangzi",
          "reason": "His strong AoE CC cleanse and immunity completely neutralizes Zhaojun's freezing strengths.",
          "hero_id": "hero_015"
        }
      ]
    }
  },
