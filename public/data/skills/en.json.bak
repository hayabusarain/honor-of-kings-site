    "strategy": {
      "strengths": [
        "Powerful CC (knockback and stun) and overwhelming durability when activating ultimate",
        "Excellent escort ability of ally carry by granting skill 2 shield"
      ],
      "weaknesses": [
        "The activation of the ultimate depends on the accumulation of the \"Madness\" gauge, making it difficult to shoot at any timing.",
        "It is difficult for shields and high HP to work against heroes with fixed damage or percentage damage."
      ],
      "playstyle": "As a roamer (support), he primarily protects his ally carry, and uses his skill 2 shield to reduce damage while filling up his own \"Madness\" gauge. In group battles, after making sure that your allies are in good shape, use your ultimate to jump into the enemy's formation and act as a vanguard wall to break up the enemy's formation. It's important to always keep pace with your team so you don't get stranded in a position where your teammates can't follow you."
    },
    "meta": {
      "summoner_spells": [
        "heel"
      ],
      "synergy": [
        {
          "hero_name": "Kara",
          "reason": "Because of Zhang Fei's shield and movement obstruction, he can unilaterally unleash high firepower from the safe rear.",
          "hero_id": "hero_088"
        },
        {
          "hero_name": "Son Naoka",
