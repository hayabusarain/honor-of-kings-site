    "difficulty": "Normal",
    "stats": {
      "survival": 4,
      "attack": 10,
      "skill": 5,
      "difficulty": 4
    },
    "passive": {
      "name": "Passive Skill: Hunter",
      "description": "While hiding in the bushes, your movement speed increases by 10-20% and charges up your stealth value (maximum value is reached in 1 second). When you come out of the bushes, you spend your latency and jump once. Jump distance increases as the latency increases.\nIf you enter the bushes, your next normal attack will be a 2-shot attack (considered as 1 normal attack), dealing 175 (70 + 60% of physical attack) physical damage per arrow (cooldown: 4 seconds).\nWhile in the bushes, damage to monsters is increased by 25%.",
      "table": {
