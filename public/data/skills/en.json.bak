    "status_text": "Max HP: 3245\nMax energy: 100\nPhysical Attack: 176 (166+10)\nMagic attack: 0\nPhysical Defense: 150 | 20%\nMagic Defense: 75 | 11.1%\nMovement Speed: 370\nPhysical Pierce: 0 | 0%\nMagic defense penetration: 0 | 0%\nAttack Speed: 10%\nCritical Rate: 0%\nCritical Damage: 200%\nPhysical Lifesteal: 0%\nMagic life steal: 0%\nCooldown Reduction: 0%\nAttack Range: long range\nResistance: 0%\nHP Regen/5s: 39\nEnergy recovery per second: 0",
    "strategy": {
      "strengths": [
        "He is a rare marksman who mainly deals magic damage, and can stably deal damage even to opponents with Physical Defense.",
        "It has excellent kite performance with normal attacks and passive step movement, and is highly mobile.",
        "By accumulating life steal (magic absorption), continuous recovery is possible, making it extremely strong in long-term battles."
      ],
      "weaknesses": [
        "It is extremely dependent on equipment, and tends to lack firepower in the early stages until you have the core items.",
        "Like other marksmen, he has low durability and is vulnerable to Assassin's burst damage and unexpected engagement.",
        "Since it relies on recovery power, its strength will be greatly reduced if the enemy is loaded with recovery-inhibiting items (anti-heal)."
      ],
      "playstyle": "In the early stages, stay behind your support, avoid unnecessary battles, and concentrate on farming and earning gold. In group battles after the middle stage when you have all the items, use your passive mobility to avoid enemy attacks and always kite at maximum range. It is ideal to use your ally's vanguard as a shield and activate your ultimate when the enemy's main skill has fallen to wipe out the enemy all at once."
    },
    "meta": {
      "summoner_spells": [
        "Flash",
        "Purify"
      ],
      "synergy": [
        {
          "hero_name": "Dun",
          "reason": "To build a stable front line with strong CC and durability, and create an environment where Erin can continuously unleash firepower from a safe distance.",
          "hero_id": "hero_027"
        },
        {
          "hero_name": "Xiang Yu",
          "reason": "Because it physically pushes back and protects enemies from approaching, Erin's survival rate increases as she fights while making use of her mobility.",
          "hero_id": "hero_036"
        }
      ],
      "counters": [
        {
          "hero_name": "Lam",
          "reason": "She is a powerful assassin who can quickly close the distance with her overwhelming mobility and instantly kill the soft Erin.",
          "hero_id": "hero_098"
        },
        {
          "hero_name": "Mai Shiranui",
          "reason": "It combines pokes from Rangeds and rapid approaches with continuous dashes, and Erin is defeated without giving her a chance to respond.",
          "hero_id": "hero_050"
        }
      ]
    }
  },
