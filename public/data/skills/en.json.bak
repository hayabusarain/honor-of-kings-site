    "strategy": {
      "strengths": [
        "His ultimate is a targeted, unavoidable lockdown, ensuring he can eliminate key enemy targets.",
        "Skill 1 can shoot down and negate enemy projectiles, completely neutralizing certain enemy mages or marksmen.",
        "His kit has built-in anti-heal through his ultimate's 'Imperil' effect, making him a hard counter to sustain-heavy heroes."
      ],
      "weaknesses": [
        "Relatively squishy for a fighter; if he gets caught by CC at the wrong time, he will be burst down quickly.",
        "Due to the nature of his ultimate, he dives deep into the enemy team and can easily be isolated and killed without allied support."
      ],
      "playstyle": "A highly mobile jungle fighter who excels at assassinating the enemy backline. Use his ultimate to lock onto the most dangerous enemy carry and burst them down. Utilize Skill 1 to block incoming projectiles and CC, and weave basic attacks between skills to consume Vigor and maximize damage. Never dive alone into 5 enemies; wait for the perfect moment to pick off isolated or vulnerable targets."
    },
    "meta": {
      "summoner_spells": [
        "Smite"
      ],
      "synergy": [
        {
          "hero_name": "Guiguzi",
          "reason": "Can group enemies up, allowing Miyamoto Musashi to hit multiple targets with his AoE skills and deal massive burst damage.",
          "hero_id": "hero_072"
