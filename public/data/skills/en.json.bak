  "hero_120": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "龍影",
        "tags": [],
        "cooldown_text": "",
        "description": "強化 ダメージ\n蒼天の龍が最後に使用したスキル2回分に応じた属性が保存される(スキルの使用毎に更新)。メイン属性は165(100%の物理攻撃)の物理ダメージを与える。サブ属性は近くに居るその他の敵に49(30%の物理攻撃)の物理ダメージを与える。スキル発動時、蒼天の龍は龍魂の刻印を1スタック獲得する(最大3スタック)。刻印獲得後、次の通常攻撃はすべての刻印を消費し、龍魂でターゲットを攻撃する。刻印を1スタック消費するごとに攻撃回数が1回増加する。この強化通常攻撃は、現在のメイン属性に応じて異なる効果をもつ。龍魂の刻印を消費して行われる追加攻撃時、2回目以降の攻撃では50%のダメージのみ与える。属性を切り替えるとき、優先的に同じ属性が保持される。",
        "table": null
      },
      {
        "id": "skill1",
        "name": "薄陽の掌炎",
        "tags": [
          "ダメージ",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "剣気を放ち、範囲内の最大3体までのターゲットに300(300+追加60%の物理攻撃)の物理ダメージと75(75+追加15%の物理攻撃)の確定ダメージ(+ターゲット後方に50%のスプラッシュダメージ)を与える。さらに追加で龍魂の刻印を1スタック獲得する。「薄陽の掌炎」を発動すると火属性を1スタック獲得し、通常攻撃に15の物理ダメージを追加する。現在保存されている属性に応じて、以下の効果を発揮する。\nメインとサブが両方火属性:ダメージが追加で50%増加する。\nメイン属性が火属性:強化通常攻撃の1回目の攻撃は103(54+30%の物理攻撃)の確定ダメージを、以降の2回の攻撃は103(54+30%の物理攻撃)の物理ダメージを与える。",
        "table": null
      },
      {
        "id": "skill2",
        "name": "不明",
        "tags": [],
        "cooldown_text": "",
        "description": "画像にスキル2の記載なし",
        "table": null
      },
      {
        "id": "skill3",
        "name": "不明",
        "tags": [],
        "cooldown_text": "",
        "description": "画像にスキル3の記載なし",
        "table": null
      },
      {
        "id": "skill4",
        "name": "夢玄龍",
        "tags": [
          "強化",
          "CC",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "最大4.5秒間、龍となって空に舞い上がる。その間は攻撃不可、地形無視、ターゲット不可状態となる(再タップで中断可能)。その後前方に急降下し(ターゲット不可状態)、ルート上の敵に400(400+追加80%の物理攻撃)の物理ダメージを与え移動速度を15%減少させ、着地点にいる敵に再度同じダメージを与えて1秒間怖縮効果を付与する。その後、10秒間攻撃速度が20%、射程が50増加し、真龍剣により攻撃を行う。この間は、2つの属性により追加で付近のターゲット最大2体に対してダメージを与える。怖縮効果を付与されたターゲットは蒼天の龍から自動的に遠ざかる。飛行中は現在保持している属性を自由に変更できる。",
        "table": null
      }
    ]
  },
  "hero_121": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "パッシブスキル：不滅の血",
        "tags": [],
        "cooldown_text": "",
        "description": "スキルを発動するとシャドークロウを召喚する。シャドークロウは自動的に付近の敵を攻撃し、毎回50（50+魔法攻撃の7%）の魔法ダメージを与え、ミニオンに対しては追加で80（80+魔法攻撃の14%）の魔法ダメージを与える（モンスターに対しては半減）。同時にHPを20（20+追加HPの0.5%）回復する。シャドークロウを召喚するとシャドーパワーを30獲得し、移動速度と回復効果が増加する。移動速度は最大で30、回復効果は10%まで増加できる。シャドークロウは最大で同時に6体まで召喚できる。シャドーパワーが0になるとクロウは消滅する。",
        "table": null
      },
      {
        "id": "skill1",
        "name": "スキル1：苦悶の一撃",
        "tags": [
          "移動",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "シャドーエネルギーを放ち、ルート上の敵に200（200+魔法攻撃の24%）の魔法ダメージを与える。再度このスキルを発動すると、永劫の美はエネルギーの位置に降臨し、付近の敵に200（200+魔法攻撃の24%）の魔法ダメージを与える。降臨が敵に命中するとシャドークロウを1体召喚する。",
        "table": null
      },
      {
        "id": "skill2",
        "name": "スキル2：幻翼の従者",
        "tags": [
          "吸収",
          "移動速度減少",
          "回復"
        ],
        "cooldown_text": "",
        "description": "前方にシャドーチェーンを放ち、最初に命中した敵と最大で4秒間リンクする。0.5秒ごとに敵に移動速度減少効果を1.25%～2.5%（スキルレベルに応じて増加）スタックさせ、10の物理攻撃と30の魔法攻撃を吸収する。また30（30+魔法攻撃の7%）の魔法ダメージを与え、10（10+追加HPの0.25%）のHPを回復する。双方の距離が1000以上離れるとチェーンは切れる。敵と4秒間リンクすると、シャドークロウを1体召喚する。パッシブ：通常攻撃が強化され、敵に200（40+物理攻撃の100%+魔法攻撃の20%）の魔法ダメージを与え、移動速度を10%減少させる。同時にシャドーパワーを10獲得する。",
        "table": null
      },
      {
        "id": "skill3",
        "name": "スキル3：暗影の月",
        "tags": [
          "無効化",
          "ダメージ",
          "移動速度増加"
        ],
        "cooldown_text": "",
        "description": "シャドーへと姿を消し、すべてのデバフ効果を解除する。その間は移動速度が30%増加し、すべての効果を無効化して2秒後に再度降臨する。シャドーに潜んでいる間及び再度降臨した時に、付近の敵全員に対し380（380+魔法攻撃の70%）の魔法ダメージを与える。降臨が敵に命中すると、シャドークロウを1体召喚する。",
        "table": null
      }
    ]
  },
  "hero_123": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "パッシブスキル：野獣の血統",
        "tags": [],
        "cooldown_text": "",
        "description": "方天画戟で攻撃するスキルが敵ヒーローに命中すると、8秒間武器がエンチャント状態になる。エンチャント状態で通常攻撃やスキルを発動すると一定の確定ダメージを与え、非エンチャント状態で通常攻撃やスキルを発動すると物理防御貫通が30%増加する。エンチャント状態で敵に通常攻撃を与えるたびに、自身のHPが80（80+追加物理攻撃の1.3%）回復する。",
        "table": null
      },
      {
        "id": "skill1",
        "name": "スキル1：双戟斬舞",
        "tags": [
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "指定方向に向かって方天画戟を振るい、範囲内の敵に570（570+追加物理攻撃の220%）の物理ダメージを与える。敵ヒーローに命中しなかった場合、方天画戟の強化状態が解除される。強化状態中は、スキル1が敵ヒーローに命中するごとに自身のHPを130（130+追加物理攻撃の2.5%）回復する。",
        "table": null
      },
      {
        "id": "skill2",
        "name": "スキル2：餓狼の魔手",
        "tags": [
          "シールド",
          "移動速度減少",
          "回復"
        ],
        "cooldown_text": "",
        "description": "指定範囲内の敵の魂を吸収し、100（100+追加物理攻撃の35%）の物理ダメージを与え、移動速度を3秒間15%減少させる。敵1体の魂を吸収するごとにシールドを1スタック獲得し、1スタックごとに350（350+追加HPの7%）のシールドを獲得する（最大3スタックまで）。シールドの25%が1秒ごとにシールド2＝HP1としてHPに変換される。",
        "table": null
      },
      {
        "id": "skill3",
        "name": "スキル3：魔神降臨",
        "tags": [
          "CC",
          "移動",
          "ダメージ"
        ],
        "cooldown_text": "",
        "description": "指定位置に降下して殺戮領域を展開し、範囲内の敵を1秒間ノックアップする。着地までCCを無効化し、着地後に方天画戟を力強く振り回して範囲内の敵に650（650+追加物理攻撃の240%）の物理ダメージを与える。エンチャント状態の場合、「魔神降臨」が命中した敵ヒーロー1体につき、自身のHPを130（130+追加物理攻撃の2.5%）回復する。殺戮領域内にいる間は自身の物理防御が150、魔法防御が150増加する。領域の縁に触れた敵には150（150+追加物理攻撃の75%）の物理ダメージを与え、2秒間移動速度を30%減少させる。敵がヒーローの場合は、追加で自身のHPを回復する。",
        "table": null
      }
    ]
  },
