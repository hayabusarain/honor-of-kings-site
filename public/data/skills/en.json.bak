    "status_text": "Max HP: 3105\nMax Mana: 0\nPhysical Attack: 159 (159+0)\nMagical Attack: 0\nPhysical Defense: 150|20%\nMagical Defense: 75|11.1%\nMovement Speed: 380\nPhysical Pierce: 0|0%\nMagical Pierce: 0|0%\nAttack Speed: 0%\nCrit Rate: 0%\nCrit Damage: 200%\nPhysical Lifesteal: 0%\nMagical Lifesteal: 0%\nCooldown Reduction: 0%\nAttack Range: Ranged\nResistance: 0%\nHP Regen/5s: 48\nMana Regen/5s: 0",
    "strategy": {
      "strengths": [
        "Incredible mobility and outplay potential with three teleportation skills.",
        "Can block all enemy projectiles with Skill 2, making her hard to burst down with ranged attacks."
      ],
      "weaknesses": [
        "Extremely squishy and reliant on perfect mechanical execution and reaction times.",
        "Highly vulnerable to targeted hard crowd control."
      ],
      "playstyle": "Constantly harass enemies with your high mobility, weaving in and out of combat by recalling to your umbrella. Use Skill 2 precisely to block critical enemy skills and projectiles. In teamfights, never stand still; reposition continuously while stacking marks on targets for burst damage."
    },
    "meta": {
      "summoner_spells": [
        "Frenzy",
        "Purify"
      ],
      "synergy": [
        {
          "hero_name": "Da Qiao",
          "reason": "Da Qiao's recall allows Gongsun Li to fully heal and instantly teleport back to her umbrella on the battlefield.",
          "hero_id": "hero_074"
        },
        {
          "hero_name": "Yao",
          "reason": "Yao's shield and buffs greatly enhance Gongsun Li's survivability while she dances around fights.",
          "hero_id": "hero_020"
        }
      ],
      "counters": [
        {
          "hero_name": "Liang",
          "reason": "His targeted suppression completely shuts down her mobility, leading to an easy kill.",
          "hero_id": "hero_049"
        },
        {
          "hero_name": "Daji",
          "reason": "Her targeted stun and burst combo can easily one-shot the extremely fragile Gongsun Li.",
          "hero_id": "hero_008"
        }
      ]
    }
  },
  "hero_082": {
    "hero_id": "082",
    "hero_name": "Ming",
    "hero_title": "Peony Diviner",
    "role": "Support",
    "sub_role": "Buff Support",
    "difficulty": "Normal",
    "stats": {
      "survival": 6,
      "attack": 4,
      "skill": 7,
      "difficulty": 3
    },
    "status_text": "Basic status\nMax HP 3330\nMax MP 620\nPhysical attack 168\nMagic attack 10 (0+10)\nPhysical defense 150|20%\nMagic defense 75|11.1%\nattack status\nMovement speed 365\nPhysical defense penetration 0|0%\nMagic defense penetration 0|0%\nAttack speed bonus 5%\nCritical rate 0%\nCritical effect 200%\nPhysical life steal 0%\nMagic life steal 0%\nCooldown reduction 0%\nAttack range long distance\ndefense status\nResistance 0%\nHP recovery every 5 seconds 46\nMP recovery every 5 seconds 15",
    "strategy": {
      "strengths": [
        "By linking with an ally carry, you can greatly enhance attack power and attack speed.",
        "You can increase the survivability of your allies through recovery and defense buffs from passive skills.",
        "It is also possible to link with enemies and inflict damage and debuffs, allowing for flexible support depending on the situation."
      ],
      "weaknesses": [
        "Unable to deal with intense burst damage that exceeds recovery and shield capacity",
        "Due to the nature of strongly buffing friendly carries, they are likely to be targeted first by the enemy team.",
        "Because it does not have HardCC, it lacks the ability to engage and peel on its own compared to a pure tank."
      ],
      "playstyle": "In the early stages, play safely and thoroughly support your ally carry's farm until you have armor and cooldown reduction items. Positioning in group battles is very important, so be aware of the exquisite sense of distance that allows you to maintain a link while not getting caught up in the enemy's area attacks or CC. Quickly switch links to strengthen your allies or weaken your enemies, depending on the situation, and protect your team's key players."
    },
    "meta": {
      "summoner_spells": [
        "treatment",
        "obstruction"
      ],
      "synergy": [
        {
          "hero_name": "Garo",
          "reason": "This allows you to further enhance the range and damage of your normal attacks with links, allowing you to annihilate enemies from a safe position.",
          "hero_id": "hero_088"
        },
        {
          "hero_name": "Gongsun Li",
          "reason": "By adding a buff to the highly mobile Marksman, it will be easier to snowball from the early stages.",
          "hero_id": "hero_081"
        }
      ],
      "counters": [
        {
          "hero_name": "Li Bai",
          "reason": "Due to high mobility and burst damage, there is a risk that all linked allies will be instantly killed.",
          "hero_id": "hero_032"
        },
        {
          "hero_name": "妲子",
          "reason": "This is because the instantaneous burst damage is high, and your allies will be defeated before Ming can recover.",
          "hero_id": "hero_008"
        }
      ]
    },
    "passive": {
