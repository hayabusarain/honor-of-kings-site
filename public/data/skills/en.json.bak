    "status_text": "Apprentice Tank 0/100\nTank/Fighter\nDefense Tank\nDash/CC\nEarly Game\nDifficulty: Normal",
    "strategy": {
      "strengths": [
        "A Fighter/Tank with abundant CC and high durability, making him an excellent frontline initiator.",
        "Provides excellent crowd control and engagement tools, including knock-ups from Skill 1 and long-range ambush potential with his Ultimate.",
        "Possesses immense resilience and comeback potential due to the powerful lifesteal granted by his passive when his HP drops below 50%."
      ],
      "weaknesses": [
        "Relies heavily on his passive for healing; vulnerable to burst damage or heavy CC chains before it can be triggered.",
        "Lacks the mobility to escape easily if he dives too deep without his team backing him up.",
        "His recovery is a key strength, making him susceptible to anti-heal items built by the enemy team."
      ],
      "playstyle": "An incredibly durable Fighter/Tank who leads the charge and acts as the team's main frontline thanks to his robust CC and survivability. A powerful tactic is to dive the enemy carries with his Ultimate, then follow up with Skill 1's knock-up to lock them down. Exploit the healing from his passive when falling below 50% HP to win tight brawls and prolonged skirmishes."
    },
    "meta": {
      "summoner_spells": [
        "Execute",
        "Flash"
      ],
      "synergy": [
        {
          "hero_name": "Gongsun Li",
          "reason": "Dun establishes the frontline and absorbs enemy skills, allowing Gongsun Li to deal free damage.",
          "hero_id": "hero_061"
        },
        {
          "hero_name": "Li Bai",
          "reason": "Dun's heavy CC locks down enemies, giving Li Bai the time to safely build his stacks and unleash burst damage.",
          "hero_id": "hero_032"
        }
      ],
      "counters": [
        {
          "hero_name": "Lu Bu",
          "reason": "His true damage ignores shields, completely nullifying Dun's durability advantage.",
          "hero_id": "hero_024"
        },
        {
          "hero_name": "Marco Polo",
          "reason": "Uses his high mobility and true damage to dodge Dun's CC while unilaterally draining his health.",
          "hero_id": "hero_033"
        }
      ]
    }
  },
