    "status_text": "status\nBasic status\nMax HP 3308\nMax MP 620\nPhysical Attack 170\nMagic attack 10(0+10)\nPhysical Defense 150|20%\nMagic defense 75|11.1%\nattack status\nMovement Speed 365\nPhysical Pierce 0|0%\nMagic defense penetration 0|0%\nAttack Speed 5%\nCritical Rate 0%\nCritical Damage 200%\nPhysical life steal 0%\nMagic life steal 0%\nCooldown Reduction 0%\nAttack Range Ranged\ndefense status\nResistance 0%\nHP Regen/5s 46\nMana Regen/5s 15",
    "strategy": {
      "strengths": [
        "You can instantly reset the cooldown of your hero's most powerful skills (mainly ultimates).",
        "Continuously recovers and supplies mana to yourself and your allies, greatly increasing your ability to continue fighting.",
        "When you are in a body of water (a river or a puddle created by a skill), CC abilities such as strong knockback will be strengthened."
      ],
      "weaknesses": [
        "It is highly dependent on allies who can easily benefit from cooldown resets, and its influence alone is low.",
        "It is strong against formations that mainly rely on skill combos and instantaneous firepower, but it is difficult to take advantage of its strengths against enemies that mainly deal continuous damage.",
        "They are vulnerable to high-mobility heroes and instantaneous burst damage, and can be easily killed if positioned incorrectly."
      ],
      "playstyle": "As a Roam Support, you can move around the map and support your allies while keeping a safe line of sight in the grass with Skill 1. During battle, make use of water bodies such as rivers, or use Skill 2 to create puddles, and be aware of how to protect your allies with enhanced skill effects. Maximize your team's potential by using your ultimate, your greatest weapon, at the right time on allies like Lu Bu and Diao Chan, who have skills that can transform team fights."
    },
    "meta": {
      "summoner_spells": [
        "treatment",
        "epiphany"
      ],
      "synergy": [
        {
          "hero_name": "Lu Bu",
          "reason": "Because Dolia can dominate teamfights by resetting the cooldown of her powerful AoE ult.",
          "hero_id": "hero_024"
        },
        {
          "hero_name": "senior official",
          "reason": "By resetting your ultimate, you can aim for a very powerful consecutive kill.",
          "hero_id": "hero_090"
        }
      ],
      "counters": [
        {
          "hero_name": "Daruma",
          "reason": "This is because you can break her position with a powerful lockdown ability and defeat her without giving her a chance to reset her ally's ultimate.",
          "hero_id": "hero_035"
        },
        {
          "hero_name": "Sumiko",
          "reason": "Continuous CC can hinder Dolia's support actions and reduce her influence in team battles.",
          "hero_id": "hero_013"
        }
      ]
    }
  },
