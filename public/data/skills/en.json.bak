    "skill4": {
      "name": "Secret techniques/concealment",
      "description": "Enters stealth state 1.5 seconds after activation (duration: 24 seconds). When you break out of stealth, your attack speed increases by 50% for 5 seconds. Staying near an enemy hero for more than 3 seconds will break stealth.",
      "tags": [
        "stealth"
