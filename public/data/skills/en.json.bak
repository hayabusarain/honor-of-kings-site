    "status_text": "Attributes\nBasic Attributes\nMax HP 3362\nMax Mana 600\nPhysical Attack 176 (166+10)\nMagical Attack 0\nPhysical Defense 150|20%\nMagical Defense 75|11.1%\nAttack Attributes\nMovement Speed 370\nPhysical Defense貫通 0|0%\nMagical Defense貫通 0|0%\nAttack Speed Bonus 10%\nCritical Rate 0%\nCritical Damage 200%\nPhysical Lifesteal 0%\nMagical Lifesteal 0%\nCooldown Reduction 0%\nAttack Range Ranged\nDefense Attributes\nResistance 0%\nHP Regen/5s 41\nMana Regen/5s 15",
    "strategy": {
      "strengths": [
        "Very high sustained firepower (DPS) in the late game",
        "Powerful engagement and CC ability from a very long distance with Ult"
      ],
      "weaknesses": [
        "Has no movement skills or blink, and is extremely vulnerable to surprise attacks from assassins.",
        "It relies heavily on support escorts and has extremely low durability in the early stages."
      ],
      "playstyle": "Since it has no mobility, it is essential that you always position yourself behind your support allies or tanks and continue hitting them with normal attacks from a safe distance. In the early stages, focus on farming without overdoing it, and demonstrate overwhelming DPS in team battles from the middle stage onward when you have all the core equipment. Ult can stun enemies far away for a long time, so use it as a powerful initiation to create kill chances for your allies."
    },
    "meta": {
      "summoner_spells": [
        "Flash"
      ],
      "synergy": [
        {
          "hero_name": "Cai Yan",
          "reason": "Continuous recovery allows you to survive longer in group fights while continuing to deal damage with normal attacks.",
          "hero_id": "hero_070"
        },
        {
          "hero_name": "Zhang Fei",
          "reason": "With his thick shield and peel ability, he can protect Hou Hui, who has low mobility, from the approach of enemy assassins.",
          "hero_id": "hero_058"
        }
      ],
      "counters": [
        {
          "hero_name": "Yunzhongjun",
          "reason": "This is because he can ignore the terrain and dive into the rearguard all at once, easily killing Hou Hui, who has no self-defense.",
          "hero_id": "hero_086"
        },
        {
          "hero_name": "Mulan",
          "reason": "They will be approached with high mobility and defeated without being able to do anything due to continuous attacks and silence.",
          "hero_id": "hero_047"
        }
      ]
    }
  },
  "hero_004": {
    "hero_id": "004",
    "hero_name": "Lian Po",
    "hero_title": "Earthshaker",
    "role": "Tank",
    "sub_role": "Vanguard Tank",
    "difficulty": "Normal",
    "stats": {
      "survival": 9,
      "attack": 4,
      "skill": 5,
      "difficulty": 4
    },
    "status_text": "Attributes\nBasic Attributes\nMax HP 3795 (3675+120)\nMax Fighting Spirit 200\nPhysical Attack 198\nMagical Attack 0\nPhysical Defense 150|20%\nMagical Defense 75|11.1%\nAttack Attributes\nMovement Speed 375\nPhysical Defense貫通 0|0%\nMagical Defense貫通 0|0%\nAttack Speed Bonus 0%\nCritical Rate 0%\nCritical Damage 200%\nPhysical Lifesteal 0%\nMagical Lifesteal 0%\nCooldown Reduction 0%\nAttack Range Melee\nDefense Attributes\nResistance 0%\nHP Regen/5s 78\nFighting Spirit Regen 0",
    "strategy": {
      "strengths": [
        "Forceful initiation ability with super armor (CC disabled) when activating skills",
        "Possesses abundant CC and high durability, and excels in controlling group battles."
      ],
      "weaknesses": [
        "It is difficult to utilize durability against enemies with fixed damage or percentage damage.",
        "Because it relies on its allies for firepower after engagement, it is easy to become isolated if cooperation cannot be established."
      ],
      "playstyle": "While it is a tank that protects its allies, it also plays the role of a powerful initiator who opens up group battles. Take advantage of CC immunity while the skill is active and dive deep into the enemy's territory, knocking up and slowing enemy carries and troublesome rear guards. Rather than dealing damage, it's more important to create an environment where your allies can attack safely, so always try to engage in tandem with your team."
    },
    "meta": {
      "summoner_spells": [
        "Flash"
      ],
      "synergy": [
        {
          "hero_name": "Alessio",
          "reason": "This is because Renki can stably inflict high firepower area damage while launching multiple enemies.",
          "hero_id": "hero_105"
        },
        {
          "hero_name": "Gongsun Li",
          "reason": "This is because marksmen can safely move around and create an opening for attacks from powerful initiations in group battles.",
          "hero_id": "hero_081"
        }
      ],
      "counters": [
        {
          "hero_name": "Diaochan",
          "reason": "While its high mobility allows it to avoid attacks, it is also able to slowly chip away at the guaranteed damage that is effective against tanks.",
          "hero_id": "hero_040"
        },
        {
          "hero_name": "Marco Polo",
          "reason": "Because it has long-distance poke and percentage damage, and Renki's durability and passive are easily ignored.",
          "hero_id": "hero_033"
        }
      ]
    },
    "passive": {
      "name": "Warrior's Soul",
      "description": "Becomes super armored while skill is active. Fighting spirit continues to increase while in combat, and increases further when a normal attack or skill hits an enemy. Acquires a damage reduction effect of 0-20% depending on the amount of fighting spirit. At maximum fighting spirit, attack speed increases by 30%. When you leave the combat state, fighting spirit is gradually converted to HP, recovering 70 (70 + 1.5% of additional HP) each time (up to 10 times)."
    },
    "skill1": {
      "name": "Burst Ram",
      "description": "Charges in the specified direction, dealing 55 (55 + 15% of additional physical attack) physical damage to enemies along the route and knocking them up for 0.5 seconds. If you are a hero, deal collision damage equal to 5% of the target's maximum HP; if you are a non-hero, deal collision damage equal to 183 (5% of your maximum HP). Passive effect: The third normal attack becomes a heavy attack, dealing an additional 250 (250 + 100% of additional physical attack) physical damage."
    },
    "skill2": {
      "name": "Magma Slam",
      "description": "After charging on the spot, inject energy into the ground with your shield and gain a 400 (400 + 10% of additional HP) shield for 5 seconds. While charging, reduces the movement speed of enemies within range by 15% and draws non-hero enemy units towards the center. After 1 second, the ground explodes, dealing 350 (350 + 90% of additional physical attack) physical damage to enemies within the area. The closer you are to the center, the more damage the enemy takes, up to a maximum of 100% additional damage. If there is an enemy within skill range while charging, reset skill 1 CD. Other skills can be activated while skill 2 is activated."
    },
    "skill3": {
      "name": "Tremor Smash",
      "description": "Jumps to the specified position and fires three blows towards the ground. The position of each hit can be adjusted using the direction keys. 1st time: Deals 220 (220 + 50% of additional physical attack) physical damage to enemies within range and reduces enemy movement speed by 15% for 1 second. Deals additional physical damage (60% of additional physical attack) to enemies in the center of the range. 2nd time: Deals 440 (440 + 100% of additional physical attack) physical damage to enemies within range and reduces enemy movement speed by 30% for 1 second. Deals additional physical damage (90% of additional physical attack) to enemies in the center of the range. 3rd time: Deals 660 (660 + 150% of additional physical attack) physical damage to enemies within range and knocks them up for 1 second. Deals collision damage equal to 10% of the target's maximum HP to heroes, and deals collision damage equal to 10% of the target's maximum HP to non-heroes. Deals additional physical damage (150% of additional physical attack) to enemies in the center of the range. Skill 1 can be activated while Skill 3 is activated."
    }
  },
