    "meta": {
      "summoner_spells": [
        "epiphany",
        "frenzy"
      ],
      "synergy": [
        {
          "hero_name": "Zhang Fei",
          "reason": "With a strong shield and CC on the first move, Loong can create an environment where he can safely deal damage.",
          "hero_id": "hero_058"
        }
      ],
      "counters": [
        {
          "hero_name": "Gongsun Li",
          "reason": "Because it is easy to avoid Loong's burst damage due to its ability to negate projectiles and high mobility.",
          "hero_id": "hero_081"
        },
        {
          "hero_name": "Yuhime",
          "reason": "Because the skill that nullifies physical damage can completely block Loong's firepower.",
          "hero_id": "hero_061"
        }
      ]
    },
    "strategy": {
      "strengths": [
        "High survival ability and excellent mobility by transforming into a dragon",
        "Different use of burst damage and continuous recovery by strengthening attributes according to skills",
        "Powerful crowd control ability that involves multiple enemies"
      ],
      "weaknesses": [
        "Highly difficult to operate, such as skill combinations and cooldown management",
        "Depends on skill rotation, so time without skills is vulnerable",
        "It depends on your standing position, and if you get caught in CC, you won't be able to utilize your strengths."
      ],
      "playstyle": "Rather than being a Marksman who focuses on simple normal attacks, you will need a fighting style that uses skills to stack Dragon Soul Marks and use enhanced attacks depending on the situation. Switch combos flexibly: fire attribute when you want to deal damage, water attribute when you want to recover, wind attribute when you need CC. Ultimate can be used not only for emergency evasion, but also as a starting point for attacks that break down enemy formations."
    }
  },
  "hero_094": {
    "hero_id": "094",
