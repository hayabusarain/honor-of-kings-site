    "strategy": {
      "strengths": [
        "Unmatched map control, able to instantly summon her entire team across the map with her Ultimate.",
        "Skill 2 allows allies to recall, fully heal, and return to the fight almost immediately."
      ],
      "weaknesses": [
        "Heavily reliant on team coordination; allies must understand her portals to maximize her potential.",
        "Relies on movement speed buffs for defense and is extremely vulnerable to AoE crowd control and burst damage."
      ],
      "playstyle": "Focus on safe positioning and vision control in the early game while protecting your carry. In the mid-to-late game, dictate the tempo by using your Ultimate for surprise ganks, objective control, or safe retreats. Be extremely careful with portal placement, as a bad portal can accidentally send a crucial teammate out of the fight."
    },
    "meta": {
      "summoner_spells": [
        "Heal",
        "Purify"
      ],
      "synergy": [
        {
          "hero_name": "Di Renjie",
          "reason": "His strong basic attacks and CC synergize well with Da Qiao's fast engages and disengages.",
          "hero_id": "hero_034"
        },
        {
          "hero_name": "Mulan",
          "reason": "Teleporting the team in to back up Mulan's ambushes can completely turn the tide of a teamfight.",
          "hero_id": "hero_047"
        }
      ],
      "counters": [
        {
          "hero_name": "Han Xin",
          "reason": "Can easily bypass the frontline with his high mobility to assassinate Da Qiao before she can support.",
          "hero_id": "hero_044"
        },
        {
          "hero_name": "Zhang Fei",
          "reason": "His strong disengage completely nullifies Da Qiao's attempt to force fights with her Ultimate.",
          "hero_id": "hero_058"
        }
      ]
    }
  },
