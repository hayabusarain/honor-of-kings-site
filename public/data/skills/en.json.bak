    "status_text": "Basic status\nMax HP: 3299\nMax MP: 600\nPhysical attack: 185 (175+10)\nMagic attack: 0\nPhysical defense: 150|20%\nMagic defense: 75|11.1%\n\nattack status\nMovement speed: 375\nPhysical defense penetration: 0|0%\nMagic defense penetration: 0|0%\nAttack speed bonus: 10%\nCritical rate: 0%\nCritical effect: 200%\nPhysical life steal: 0%\nMagic life steal: 0%\nCooldown reduction: 0%\nAttack range: long range\n\ndefense status\nResistance: 0%\nHP recovery every 5 seconds: 37\nMP recovery every 5 seconds: 15",
    "strategy": {
      "strengths": [
        "Hit and away tactics that take advantage of high mobility and stable continuous firepower in the late stages",
        "High control of the board through the ability to secure visibility and control areas using traps and summoned beasts"
      ],
      "weaknesses": [
        "Because it depends on the placement and timing of traps and summoned beasts, the player's skill in reading the battle situation is tested.",
        "Has low durability, and once caught by hard CC, there is a high risk of being defeated without being able to escape."
      ],
      "playstyle": "Operate in the farm lane, place traps in bushes and choke points, and safely farm while watching out for enemy ganks. In group battles, it is important to take advantage of your high mobility to always maintain a safe distance from the enemy, and to carry out kite attacks that constantly output damage with normal attacks and skills. Don't move too far forward, and use the advantage of visibility provided by the trap to continue attacking from a favorable position."
    },
    "meta": {
      "summoner_spells": [
        "epiphany",
        "heel"
      ],
      "synergy": [
        {
          "hero_name": "Zhang Fei",
          "reason": "With his thick shield and powerful peel ability, he can create an environment where Ao, who is vulnerable to attacks, can attack safely while setting up traps.",
          "hero_id": "hero_058"
        },
        {
          "hero_name": "Gyuma",
          "reason": "This is because it can stop the enemy in its tracks with a variety of action hindrances, and support Ao with accurate long-range attacks and skills.",
          "hero_id": "hero_056"
        }
      ],
      "counters": [
        {
          "hero_name": "King Lanling",
          "reason": "Because of surprise attacks from stealth and high burst damage, you will be instantly killed before you can use your mobility to escape.",
          "hero_id": "hero_046"
        },
        {
          "hero_name": "miyamoto musashi",
          "reason": "In order to completely contain Ao's strength, Hit & Away, by using powerful targeted dives and movement obstruction.",
          "hero_id": "hero_031"
        }
      ]
    }
  },
