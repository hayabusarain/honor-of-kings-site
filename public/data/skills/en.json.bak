    "status_text": "Attributes\nBasic Attributes\nMax HP 3650\nMax Mana 600\nPhysical Attack 188\nMagical Attack 0\nPhysical Defense 150|20%\nMagical Defense 75|11.1%\nAttack Attributes\nMovement Speed 375\nPhysical Defense貫通 0|0%\nMagical Defense貫通 0|0%\nAttack Speed Bonus 5%\nCritical Rate 0%\nCritical Damage 200%\nPhysical Lifesteal 0%\nMagical Lifesteal 0%\nCooldown Reduction 0%\nAttack Range Melee\nDefense Attributes\nResistance 0%\nHP Regen/5s 80\nMana Regen/5s 15",
    "strategy": {
      "strengths": [
        "His role is highly flexible during the draft, making it difficult for opponents to predict him.",
        "Customizable and can be used as a tank to enhance defense and utility."
      ],
      "weaknesses": [
        "Although it is highly flexible, it is less likely to have sharp strengths compared to specialized heroes.",
        "Easily affected by changes in meta, optimization requires understanding of multiple roles"
      ],
      "playstyle": "It is important to determine roles according to the composition of the team during the pre-game draft stage and optimize equipment and arcana for tanks. Utilize the passive \"flow\" buff to increase your durability on the front lines, while making full use of CC to hinder enemy movement. Since it does not have sharp performance compared to specialized heroes, it is necessary to compensate by cooperating with allies and fighting."
    },
    "meta": {
      "summoner_spells": [
        "Flash",
        "Execute"
      ],
      "synergy": [
        {
          "hero_name": "Hou Yi",
          "reason": "It acts as a wall on the front lines, protecting less mobile marksmen from enemy dives.",
          "hero_id": "hero_003"
        },
        {
          "hero_name": "Zhuge Liang",
          "reason": "Because it can restrain multiple enemies with powerful CC and safely draw out wide-range damage from mages.",
          "hero_id": "hero_073"
        }
      ],
      "counters": [
        {
          "hero_name": "Marco Polo",
          "reason": "This is because it has defense penetration and percentage damage, and the high durability of tanks is ignored.",
          "hero_id": "hero_033"
        },
        {
          "hero_name": "Lu Bu",
          "reason": "This is because it has guaranteed damage that nullifies shields and physical defenses, so it cannot be prevented.",
          "hero_id": "hero_024"
        }
      ]
    }
  },
