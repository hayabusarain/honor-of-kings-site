    "skill3": {
      "name": "Skill 3: Verdant Protector",
      "tags": [
        "shield",
        "reinforcement"
      ],
      "cooldown": "CD : 15s",
      "description": "Possesses another allied hero and grants a shield that absorbs all damage for 750 (750 + 50% of magic damage + 10% of maximum HP). When possessed, the CD of all skills is reduced by 30%. When the shield is destroyed, the possessed state is removed and the character enters Cooldown. If you remove possession from yourself, 50% of your cooldown will be returned.\nDeer status: Gives nearby allies a movement speed increase effect.",
