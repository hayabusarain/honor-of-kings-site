  "hero_083": {
    "hero_id": "083",
    "hero_name": "Pei",
    "hero_title": "Tiger Fist",
    "role": "Assassin",
    "sub_role": "Roam type Assassin",
    "difficulty": "Hard",
    "stats": {
      "survival": 4,
      "attack": 8,
      "skill": 6,
      "difficulty": 6
    },
    "status_text": "Basic status\nMax HP 3238\nMax energy 200\nPhysical attack 175 (165+10)\nMagic attack 0\nPhysical defense 150|20%\nMagic defense 75|11.1%\nattack status\nMovement speed 380\nPhysical defense penetration 0|0%\nMagic defense penetration 0|0%\nAttack speed bonus 5%\nCritical rate 0%\nCritical effect 200%\nPhysical life steal 0%\nMagic life steal 0%\nCooldown reduction 0%\nAttack range long distance\ndefense status\nResistance 0%\nHP recovery every 5 seconds 45\nEnergy recovery every 5 seconds 50",
    "strategy": {
      "strengths": [
        "All skills can be used from level 1, no mana required, and jungle control in the early stages is very high.",
        "You can use long-range poke in human form and high mobility and burst firepower in tiger form.",
        "Utilizing the wall-passing skill of the tiger form, you can quickly move around the map and powerfully support each lane."
      ],
      "weaknesses": [
        "If you can't build up an advantage early on, your influence will be lower in late team fights compared to other scaling heroes.",
        "Since it does not have strong HardCC, it is highly dependent on support from allies to restrain the target.",
        "It is necessary to perfectly manage the two forms and energy, and it is easy to be defeated if you switch at the wrong time."
      ],
      "playstyle": "Immediately after the start of the match, your main objective is to work with your allies to invade the enemy jungle, steal buffs, and control the tempo in the early stages. Manage your energy while reducing the enemy's health from a distance in human form, then switch to tiger form the moment you reach the kill line to deliver the final blow. In teamfights, it's important not to rush in blindly, and only aim for soft backline heroes or only use them in situations where you're sure of a kill and a safe exit."
    },
    "meta": {
      "summoner_spells": [
        "punishment"
      ],
      "synergy": [
        {
          "hero_name": "Gyuma",
          "reason": "This is because it provides strong CC and defense buffs from the early stages and can support Pei's aggressive jungle invasion.",
          "hero_id": "hero_056"
        },
        {
          "hero_name": "100 miles of promise",
          "reason": "Poke from a distance will reduce the enemy's health, making it easier for Pei to collect kills in tiger form.",
          "hero_id": "hero_078"
        }
      ],
      "counters": [
        {
          "hero_name": "Diao cicada",
          "reason": "With high mobility and invincibility time, you can avoid Pei's burst, and on the other hand, you are likely to be attacked.",
          "hero_id": "hero_040"
        },
        {
          "hero_name": "Sun Yin",
          "reason": "Pei's kill potential can be significantly lowered with health rewind and movement buffs in team fights.",
          "hero_id": "hero_020"
        }
      ]
    },
