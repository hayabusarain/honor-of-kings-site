  "hero_533": {
    "lore": "",
    "skills": [
      {
        "id": "P",
        "name": "山の奇縁",
        "tags": [],
        "cooldown_text": "",
        "description": "モンスターたちとの不思議な縁により、モンスターに近づくと回復がリリースとなる（バフを獲得）。\n通常攻撃が敵に命中すると種爆弾をドロップしながら、周囲の種爆弾を引き寄せる。種爆弾を自分で拾うと2.5秒間、攻撃速度と移動速度が3%増加する（最大6スタックまで）。\n敵が種爆弾に触れると30（30+追加物理攻撃の10%）の物理ダメージを与える。",
        "table": null
