        {
          "form_name": "Resonance / 3 stacks: True intention / Ryohara",
          "description": "After jumping into the air and gathering strength, it unleashes a ferocious blow. Deals 333 (160 + 100% of physical attack) physical damage to enemies on the route (the lower the target's HP, the more damage). The damage is maximized when the target's HP falls below 50%, dealing 666 (320 + 200% of physical attack) physical damage.\nIf you attack normally with 3 resonance stacks, you can ignore the terrain while jumping up. Additionally, movement speed increases by 200% and damage taken is reduced by 10%.",
          "table": null
        }
      ]
    },
    "strategy": {
      "strengths": [
        "Possesses high mobility and pursuit ability due to abundant dash skills and passives.",
        "Possesses multiple CC skills and can disrupt and control enemies while dealing damage."
      ],
      "weaknesses": [
        "Defense depends on items and skills, and if you receive a CC chain, you will be defeated without being able to do anything.",
        "Judgment and operational precision are required to use three types of passives depending on the situation."
      ],
      "playstyle": "The biggest key is to use the passive attack, which changes into three stages depending on the number of times you use the skill, depending on the situation. Select the 1st stage when you want to close the distance, the 2nd stage when you want to deal continuous damage, and the 3rd stage when you want to deal a blow while avoiding the enemy's attack. As a jungler, gank aggressively from the start, use your mobility to quickly take out isolated enemies, and control the tempo of the entire map."
    },
    "meta": {
      "summoner_spells": [
        "Smite"
      ],
      "synergy": [
        {
          "hero_name": "Dyadia",
          "reason": "This is because you can control the enemy, create a reliable opening, and create a situation where you can start a combo from a dive.",
          "hero_id": "hero_111"
        },
        {
          "hero_name": "Yaria",
          "reason": "It provides shielding and protection, greatly increasing your chances of survival when diving deep into enemy lines.",
          "hero_id": "hero_085"
        }
      ],
      "counters": [
        {
          "hero_name": "Di Renjie",
          "reason": "Because it has its own CC release ability and stun, it can easily counterattack divers.",
          "hero_id": "hero_034"
        },
        {
          "hero_name": "Lady Sun",
          "reason": "Their high mobility keeps them at a distance, and their high firepower burst damage cuts them down before they can get close.",
          "hero_id": "hero_014"
        }
      ]
    }
  },
