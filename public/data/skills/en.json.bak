    "skill3": {
      "name": "Migata",
      "description": "Acquires 1 stack of ``Migata'' at regular intervals (up to 2 stacks), and when used, activates ``Kyoka Suigetsu'' and replaces its position with its mirror image.",
      "tags": [
        "move"
      ],
      "cooldown": "CD: 0 seconds",
      "table": {
        "headers": [],
        "rows": []
      }
    },
    "skill4": {
      "name": "Kyoka Suigetsu",
      "description": "Charges forward, stuns enemies along the route for 0.5 seconds, and creates a mirror space when it reaches the end. When the space is expanded, enemies in the rush path are drawn to the center of the space. Deployment duration is 10 seconds.\nAfter deploying in space, when a skill is activated or the main body and mirror image perform a normal attack, mirror shards will fly towards the enemy, dealing slashing damage equal to 2% of the target's lost HP. Enemies that touch the edge of the space will take 30 (30 + 30% of physical attack) physical damage and have their movement speed reduced by 50%. While in space, damage taken is reduced by 10% and HP is recovered by 10 (10 + 40% of physical attack) every second.",
      "tags": [
        "move",
        "damage"
      ],
      "cooldown": "CD: 40 seconds",
      "table": {
        "headers": [
          "Lv.1",
          "Lv.2",
          "Lv.3"
        ],
        "rows": [
          {
            "label": "cool down",
