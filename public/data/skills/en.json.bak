    "status_text": "Max HP: 3314\nMax Mana: 620\nPhysical Attack: 167\nMagical Attack: 10 (0+10)\nPhysical Defense: 150|20%\nMagical Defense: 75|11.1%\nMovement Speed: 365\nPhysical Pierce: 0|0%\nMagical Pierce: 0|0%\nAttack Speed: 5%\nCrit Rate: 0%\nCrit Damage: 200%\nPhysical Lifesteal: 0%\nMagical Lifesteal: 0%\nCooldown Reduction: 0%\nAttack Range: Ranged\nResistance: 0%\nHP Regen/5s: 38\nMana Regen/5s: 15",
    "strategy": {
      "strengths": [
        "Unmatched sustain and capability in protracted teamfights thanks to her constant AoE healing.",
        "Excellent protective ability with her Skill 2 bouncing stun and Ultimate's defense and healing buffs."
      ],
      "weaknesses": [
        "Her support potential drops significantly if enemies purchase anti-heal items.",
        "Vulnerable to high burst damage that can instantly eliminate her or her allies before she can heal them."
      ],
      "playstyle": "A support specializing in closely guarding the team's carry (like a Marksman). Keep your allies' HP high in the early game to dominate the laning phase. In teamfights, fire Skill 2 into grouped enemies for multiple stuns, and immediately activate your Ultimate if allies are in danger. Always be mindful of your positioning to avoid getting targeted first."
    },
    "meta": {
      "summoner_spells": [
        "Heal",
        "Stun"
      ],
      "synergy": [
        {
          "hero_name": "Hou Yi",
          "reason": "Provides massive healing and peel, creating a safe environment for Hou Yi to stand and deliver high sustained damage.",
          "hero_id": "hero_003"
        },
        {
          "hero_name": "Gao Jianli",
          "reason": "Significantly boosts Gao Jianli's survivability when diving into the enemy team, maximizing the impact of his Ultimate.",
          "hero_id": "hero_017"
        }
      ],
      "counters": [
        {
          "hero_name": "Musashi",
          "reason": "Musashi's Ultimate anti-heal effect completely negates her core strength of sustaining the team.",
          "hero_id": "hero_031"
        },
