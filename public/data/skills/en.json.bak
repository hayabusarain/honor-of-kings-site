    "status_text": "Apprentice support 0/100\nSupport/Mage\nOffensive Support\nCC/first move\nearly stage\nDifficulty: Hard\ndefense status\nresistance 0%\nHP recovery every 5 seconds 79\nMP recovery every 5 seconds 15",
    "strategy": {
      "strengths": [
        "Powerful forced movement using skill 2's hook allows you to drag enemies into friendly territory.",
        "It can put pressure on enemy jungles and lanes from the early stages and provide powerful AoE CC with its ultimate."
      ],
      "weaknesses": [
        "Most of the performance depends on the accuracy of the hook, and there is a significant gap and pressure drop when it is missed.",
        "It has low mobility and has no means of escaping if brought into close combat."
      ],
      "playstyle": "He mainly plays as a roamer (support), and from the beginning he actively works to obstruct the enemy and secure his line of sight, keeping the pressure on. Before and after a group fight, your biggest role is to use a hook to pull out the enemy's rear carry and use your ultimate CC combo to defeat them in an instant. If you accidentally attract a powerful enemy tank or engager, you risk annihilating your allies, so choose your targets carefully."
    },
    "meta": {
      "summoner_spells": [
        "Fainting",
        "epiphany"
      ],
      "synergy": [
        {
          "hero_name": "Huang Zhong",
          "reason": "This is because Shoki can instantly destroy enemies that he has drawn in with his hook using overwhelming firepower.",
          "hero_id": "hero_075"
        },
        {
          "hero_name": "Son Naoka",
          "reason": "This is because it is easy to inflict high-power burst damage on the enemy you have drawn and instantly kill them.",
          "hero_id": "hero_014"
        }
      ],
      "counters": [
        {
          "hero_name": "Cao Cao",
          "reason": "Due to its high sustain ability and interference resistance, it is easy to escape from Shoki's control, and on the contrary, it is counterattacked.",
          "hero_id": "hero_029"
        },
        {
          "hero_name": "Kaiser",
          "reason": "While the ultimate is activated, it is very hard, and if you pull it back, there is a risk that your allies will receive great damage.",
          "hero_id": "hero_076"
        }
      ]
    }
  },
