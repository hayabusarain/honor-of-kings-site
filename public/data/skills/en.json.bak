          "reason": "Can quickly close the gap with high mobility and easily assassinate her while she is immobilized during her ultimate.",
          "hero_id": "hero_044"
        },
        {
          "hero_name": "Daji",
          "reason": "Can stop her with a targeted hard CC and burst her down instantly.",
          "hero_id": "hero_008"
        }
      ]
    }
  },
