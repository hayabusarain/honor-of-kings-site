    "status_text": "Angela Scorchette Adjustment Trainee Mage 0/100 Mage Artillery Mage Burst/Shield Balance Difficulty: Normal",
    "strategy": {
      "strengths": [
        "Extremely high burst damage capable of melting single targets instantly.",
        "Fast wave clear with skills, and her ultimate provides a shield and Control Immunity for self-protection."
      ],
      "weaknesses": [
        "Skill trajectories are easy to predict and can be easily dodged by highly mobile heroes.",
        "Cannot move during her ultimate, making her vulnerable if the shield breaks."
      ],
      "playstyle": "The core playstyle is to poke from the backline and unleash a full combo the moment Skill 2 stuns an enemy. Since she cannot move during her ultimate, you must understand enemy positioning and CC to find safe moments to unleash your damage. Ambushes from bushes are highly effective."
    },
    "meta": {
      "summoner_spells": [
        "Flash"
      ],
      "synergy": [
        {
          "hero_name": "Zhuangzhou",
          "reason": "Can cleanse CC, making it safer for her to channel her ultimate without being interrupted.",
          "hero_id": "hero_015"
        },
        {
